{% comment %}
  Media & Press -- Book Kapil CTA
  Bottom call-to-action with bio paragraph and booking button.
  Based on the about-final-cta.liquid pattern, extended with rich text bio.
{% endcomment %}

<section
  id="nb-media-cta-{{ section.id }}"
  class="nb-media-cta {{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings.pad_top }}px; padding-block-end: {{ section.settings.pad_bottom }}px;"
>
  <div class="nb-shell">
    <div
      class="nb-media-cta__wrap"
      {% if section.settings.panel_on %}style="--nb-panel-bg: {{ section.settings.panel_color | default: '#F3FAF8' }};"{% endif %}
    >
      {% if section.settings.kicker != blank %}
        <p class="nb-kicker nb-media-cta__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      <h2 class="nb-h2 nb-media-cta__title">{{ section.settings.heading }}</h2>

      {% if section.settings.bio != blank %}
        <div class="nb-rte nb-media-cta__bio">{{ section.settings.bio }}</div>
      {% endif %}

      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <div class="nb-media-cta__actions">
          <a class="nb-cta nb-cta--xl" href="{{ section.settings.cta_link }}" data-cta="media-cta">{{ section.settings.cta_label }}</a>
        </div>
      {% endif %}
    </div>
  </div>

  <style>
    .nb-media-cta .nb-media-cta__wrap {
      text-align: center;
      background: {% if section.settings.panel_on %}var(--nb-panel-bg, var(--nb-mist, #F3FAF8)){% else %}transparent{% endif %};
      border-radius: 20px;
      padding: clamp(28px, 4vw, 48px) clamp(18px, 3vw, 36px);
      box-shadow: {% if section.settings.panel_on %}0 10px 28px rgba(12,138,123,.08), 0 1px 0 rgba(255,255,255,.8) inset{% else %}none{% endif %};
    }

    .nb-media-cta__bio {
      max-width: 680px;
      margin: 0 auto 18px;
      opacity: .92;
      line-height: 1.65;
      font-size: clamp(14px, 1.1vw, 16px);
    }

    .nb-media-cta__actions {
      margin-top: 14px;
    }

    .nb-media-cta .nb-kicker {
      margin: 0 0 8px;
      opacity: .85;
    }
  </style>
</section>

{% schema %}
{
  "name": "Media -- CTA",
  "class": "section-wrapper nb-media-cta-wrap",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Get in Touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Book Kapil for Your Podcast or Event" },
    { "type": "richtext", "id": "bio", "label": "Bio paragraph", "default": "<p>Kapil Gupta is the founder of Nibana and creator of the Performance to Presence Method. He works 1:1 with founders, executives, and couples globally. He is a co-author of \"Being FINE: The Other F Word\" and his TEDx talk \"Dare To Be Sensitive\" has been viewed over 136,000 times. He is a Fellow of the Royal Society of Arts (FRSA).</p>" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Get in Touch" },
    { "type": "text", "id": "cta_link", "label": "CTA link", "default": "/pages/contact" },
    { "type": "checkbox", "id": "panel_on", "label": "Show panel background", "default": true },
    { "type": "color", "id": "panel_color", "label": "Panel background color", "default": "#F3FAF8" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "pad_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "Media -- CTA" }
  ]
}
{% endschema %}
