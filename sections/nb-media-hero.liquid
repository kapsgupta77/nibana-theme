{% comment %}
  Media & Press -- Hero section
  Clean, centered hero with kicker, heading, and subheadline.
  Matches the about-hero.liquid pattern, simplified (no image).
{% endcomment %}

<section
  id="nb-media-hero-{{ section.id }}"
  class="nb-media-hero {{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings.pad_top }}px; padding-block-end: {{ section.settings.pad_bottom }}px;"
>
  <div class="nb-shell">
    <div
      class="nb-media-hero__wrap"
      {% if section.settings.panel_on %}style="--nb-panel-bg: {{ section.settings.panel_color | default: '#F3FAF8' }};"{% endif %}
    >
      {% if section.settings.kicker != blank %}
        <p class="nb-kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      <h1 class="nb-h1 nb-media-hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.sub_rich != blank %}
        <div class="nb-rte nb-media-hero__sub">{{ section.settings.sub_rich }}</div>
      {% endif %}
    </div>
  </div>

  <style>
    .nb-media-hero .nb-media-hero__wrap {
      text-align: center;
      background: {% if section.settings.panel_on %}var(--nb-panel-bg, var(--nb-mist, #F3FAF8)){% else %}transparent{% endif %};
      border-radius: 20px;
      padding: clamp(28px, 4vw, 56px) clamp(18px, 3vw, 40px);
      box-shadow: {% if section.settings.panel_on %}0 10px 28px rgba(12,138,123,.08), 0 1px 0 rgba(255,255,255,.8) inset{% else %}none{% endif %};
    }

    .nb-media-hero .nb-media-hero__title {
      margin: 0 0 10px;
      line-height: 1.08;
    }

    .nb-media-hero .nb-media-hero__sub {
      margin: 0 auto;
      max-width: 640px;
      opacity: .92;
      font-size: clamp(15px, 1.2vw, 18px);
      line-height: 1.55;
    }

    .nb-media-hero .nb-kicker {
      margin: 0 0 10px;
      opacity: .85;
    }
  </style>
</section>

{% schema %}
{
  "name": "Media -- Hero",
  "class": "section-wrapper nb-media-hero-wrap",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Media & Press" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Media & Press" },
    { "type": "richtext", "id": "sub_rich", "label": "Subheadline", "default": "<p>Featured in GQ, Men's Health, The Sun, Thrive Global, and more</p>" },
    { "type": "checkbox", "id": "panel_on", "label": "Show panel background", "default": true },
    { "type": "color", "id": "panel_color", "label": "Panel background color", "default": "#F3FAF8" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "pad_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "Media -- Hero" }
  ]
}
{% endschema %}
