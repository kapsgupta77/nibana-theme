{%- liquid
  assign image = section.settings.image
-%}
<section id="nb-home-hero-{{ section.id }}" class="nb-home-hero color-{{ section.settings.color_scheme }}">
  <div class="nb-home-hero__wrap">
    <div class="nb-home-hero__copy">
      {%- if section.settings.overline != blank -%}<p class="nb-home-hero__overline">{{ section.settings.overline }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="nb-home-hero__heading">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<div class="nb-home-hero__subheading">{{ section.settings.subheading }}</div>{%- endif -%}
      <div class="nb-home-hero__actions">
        {%- if section.settings.primary_label != blank and section.settings.primary_link != blank -%}<a class="button nb-home-hero__button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>{%- endif -%}
        {%- if section.settings.secondary_label != blank and section.settings.secondary_link != blank -%}<a class="nb-home-hero__secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{%- endif -%}
      </div>
      {%- if section.settings.microcopy != blank -%}<p class="nb-home-hero__microcopy">{{ section.settings.microcopy }}</p>{%- endif -%}
    </div>
    <div class="nb-home-hero__media">
      {%- if image != blank -%}
        {{ image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '420, 640, 900, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw', class: 'nb-home-hero__image' }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg nb-home-hero__image' }}
      {%- endif -%}
    </div>
  </div>
</section>
{% style %}
#nb-home-hero-{{ section.id }}{
  --nb-home-ink:#223238;--nb-home-cream:#f7f1e8;--nb-home-teal:#10636c;
  --nb-home-button-h:48px;--nb-home-button-x:24px;--nb-home-hero-copy-measure:760px;--nb-home-hero-copy-size:var(--nb-home-type-body);
  background:rgb(var(--color-background));color:rgb(var(--color-foreground));
}
#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{max-width:min(1440px,100vw);margin:0 auto;display:grid;grid-template-columns:minmax(0,1.18fr) minmax(360px,.82fr);align-items:stretch;min-height:clamp(640px,76vh,820px);}
#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:clamp(86px,8.2vw,132px) clamp(40px,8vw,128px);display:flex;flex-direction:column;justify-content:center;}
#nb-home-hero-{{ section.id }} .nb-home-hero__overline{margin:0 0 16px;font-family:var(--font-body--family);font-size:var(--nb-home-type-overline);letter-spacing:.13em;text-transform:uppercase;opacity:.64;line-height:1.35;}
#nb-home-hero-{{ section.id }} .nb-home-hero__heading{margin:0;max-width:var(--nb-home-hero-copy-measure);font-family:var(--font-heading--family);font-size:var(--nb-home-type-hero-heading);line-height:1.02;letter-spacing:-.035em;font-weight:500;text-wrap:balance;}
#nb-home-hero-{{ section.id }} .nb-home-hero__subheading{max-width:var(--nb-home-hero-copy-measure);margin:28px 0 0;font-family:var(--font-body--family);font-size:var(--nb-home-hero-copy-size);line-height:1.62;opacity:.84;}
#nb-home-hero-{{ section.id }} .nb-home-hero__subheading p{margin:0;}
#nb-home-hero-{{ section.id }} .nb-home-hero__actions{display:flex;gap:16px 20px;align-items:center;flex-wrap:wrap;margin-top:36px;}
#nb-home-hero-{{ section.id }} .button{min-height:var(--nb-home-button-h);padding:0 var(--nb-home-button-x);background:var(--nb-home-teal);color:#fff;text-decoration:none;border-radius:999px;font-family:var(--font-body--family);font-size:var(--nb-home-hero-copy-size);font-weight:700;letter-spacing:.01em;}
#nb-home-hero-{{ section.id }} .button:hover{background:#0b4f56;}
#nb-home-hero-{{ section.id }} .nb-home-hero__secondary{font-family:var(--font-body--family);color:currentColor;text-underline-offset:6px;text-decoration-thickness:1px;font-size:var(--nb-home-hero-copy-size);font-weight:650;opacity:.84;}
#nb-home-hero-{{ section.id }} .nb-home-hero__microcopy{margin:20px 0 0;max-width:var(--nb-home-hero-copy-measure);font-family:var(--font-body--family);font-size:var(--nb-home-hero-copy-size);line-height:1.55;opacity:.58;}
#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:420px;overflow:hidden;}
#nb-home-hero-{{ section.id }} .nb-home-hero__image{display:block;width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.image_position }};}
@media(min-width:990px){#nb-home-hero-{{ section.id }} .nb-home-hero__image{transform:scale(.985);transform-origin:center;}}
@media(max-width:989px){#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{grid-template-columns:1fr;min-height:0;}#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:64px 28px 46px;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:420px;order:2;}#nb-home-hero-{{ section.id }}{--nb-home-hero-copy-measure:100%;}}
@media(max-width:749px){#nb-home-hero-{{ section.id }} .nb-home-hero__actions{align-items:stretch;flex-direction:column;}#nb-home-hero-{{ section.id }} .button{justify-content:center;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:340px;}}
{% endstyle %}
{% schema %}
{
  "name": "NB — Home hero",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center top",
          "label": "Top"
        },
        {
          "value": "center 35%",
          "label": "Upper centre"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NB — Home hero"
    }
  ]
}
{% endschema %}
