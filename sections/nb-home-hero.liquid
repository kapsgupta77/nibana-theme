{%- liquid
  assign image = section.settings.image
-%}
<section id="nb-home-hero-{{ section.id }}" class="nb-home-hero color-{{ section.settings.color_scheme }}">
  <div class="nb-home-hero__wrap">
    <div class="nb-home-hero__copy">
      {%- if section.settings.overline != blank -%}<p class="nb-home-hero__overline">{{ section.settings.overline }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="nb-home-hero__heading">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<div class="nb-home-hero__subheading">{{ section.settings.subheading }}</div>{%- endif -%}
      <div class="nb-home-hero__actions">
        {%- if section.settings.primary_label != blank and section.settings.primary_link != blank -%}<a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>{%- endif -%}
        {%- if section.settings.secondary_label != blank and section.settings.secondary_link != blank -%}<a class="nb-home-hero__secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{%- endif -%}
      </div>
      {%- if section.settings.microcopy != blank -%}<p class="nb-home-hero__microcopy">{{ section.settings.microcopy }}</p>{%- endif -%}
    </div>
    <div class="nb-home-hero__media">
      {%- if image != blank -%}
        {{ image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '420, 640, 900, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw', class: 'nb-home-hero__image' }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg nb-home-hero__image' }}
      {%- endif -%}
    </div>
  </div>
</section>
{% style %}
#nb-home-hero-{{ section.id }}{background:rgb(var(--color-background));color:rgb(var(--color-foreground));}
#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{max-width:var(--page-width,1200px);margin:0 auto;display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.95fr);align-items:stretch;min-height:clamp(560px,70vh,760px);}
#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:clamp(64px,8vw,132px) clamp(20px,6vw,88px);display:flex;flex-direction:column;justify-content:center;}
#nb-home-hero-{{ section.id }} .nb-home-hero__overline{margin:0 0 18px;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;opacity:.72;}
#nb-home-hero-{{ section.id }} .nb-home-hero__heading{margin:0;max-width:12ch;font-family:var(--font-heading--family);font-size:clamp(4rem,6.2vw,8.8rem);line-height:.95;letter-spacing:-.04em;text-wrap:balance;}
#nb-home-hero-{{ section.id }} .nb-home-hero__subheading{max-width:54ch;margin:24px 0 0;font-size:clamp(1.5rem,1.45vw,1.9rem);line-height:1.58;opacity:.86;}
#nb-home-hero-{{ section.id }} .nb-home-hero__subheading p{margin:0;}
#nb-home-hero-{{ section.id }} .nb-home-hero__actions{display:flex;gap:18px;align-items:center;flex-wrap:wrap;margin-top:30px;}
#nb-home-hero-{{ section.id }} .button{min-height:44px;padding:0 22px;background:var(--nb-teal,#10636c);color:#fff;text-decoration:none;}
#nb-home-hero-{{ section.id }} .nb-home-hero__secondary{color:currentColor;text-underline-offset:5px;text-decoration-thickness:1px;font-size:1.4rem;}
#nb-home-hero-{{ section.id }} .nb-home-hero__microcopy{margin:18px 0 0;font-size:1.25rem;line-height:1.5;opacity:.65;}
#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:420px;}
#nb-home-hero-{{ section.id }} .nb-home-hero__image{display:block;width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.image_position }};}
@media(max-width:989px){#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{grid-template-columns:1fr;min-height:0;}#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:56px 24px 36px;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:420px;order:2;}#nb-home-hero-{{ section.id }} .nb-home-hero__heading{font-size:clamp(4.2rem,14vw,6.8rem);}}
@media(max-width:749px){#nb-home-hero-{{ section.id }} .nb-home-hero__actions{align-items:stretch;flex-direction:column;}#nb-home-hero-{{ section.id }} .button{justify-content:center;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:360px;}}
{% endstyle %}
{% schema %}
{
  "name": "NB — Home hero",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center top",
          "label": "Top"
        },
        {
          "value": "center 35%",
          "label": "Upper centre"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NB — Home hero"
    }
  ]
}
{% endschema %}
