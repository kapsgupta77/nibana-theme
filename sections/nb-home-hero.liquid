{%- liquid
  assign image = section.settings.image
-%}
<section id="nb-home-hero-{{ section.id }}" class="nb-home-hero color-{{ section.settings.color_scheme }}">
  <div class="nb-home-hero__wrap">
    <div class="nb-home-hero__copy">
      {%- if section.settings.overline != blank -%}<p class="nb-home-hero__overline">{{ section.settings.overline }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="nb-home-hero__heading">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<div class="nb-home-hero__subheading">{{ section.settings.subheading }}</div>{%- endif -%}
      <div class="nb-home-hero__actions">
        {%- if section.settings.primary_label != blank and section.settings.primary_link != blank -%}<a class="button nb-home-hero__button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>{%- endif -%}
        {%- if section.settings.secondary_label != blank and section.settings.secondary_link != blank -%}<a class="nb-home-hero__secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{%- endif -%}
      </div>
      {%- if section.settings.microcopy != blank -%}<p class="nb-home-hero__microcopy">{{ section.settings.microcopy }}</p>{%- endif -%}
    </div>
    <div class="nb-home-hero__media">
      {%- if image != blank -%}
        {{ image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '420, 640, 900, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw', class: 'nb-home-hero__image' }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg nb-home-hero__image' }}
      {%- endif -%}
    </div>
  </div>
</section>
{% style %}
#nb-home-hero-{{ section.id }}{
  --nb-home-ink:#28313b;
  --nb-home-cream:#e9e8de;
  --nb-home-teal:#14757c;
  --nb-home-teal-dark:#10636c;
  --nb-home-hero-heading-measure:620px;
  --nb-home-hero-copy-measure:620px;
  --nb-home-button-h:72px;
  --nb-home-button-x:38px;
  --nb-home-header-offset:var(--header-height,96px);
  background:var(--nb-home-cream);
  color:var(--nb-home-ink);
}
#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{max-width:none;margin:0;display:grid;grid-template-columns:minmax(560px,48vw) minmax(0,52vw);align-items:stretch;min-height:clamp(560px,68vh,680px);}
#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:clamp(52px,6vh,82px) clamp(44px,6vw,116px) clamp(42px,5vh,68px);display:flex;flex-direction:column;justify-content:center;}
#nb-home-hero-{{ section.id }} .nb-home-hero__overline{margin:0 0 clamp(18px,2.2vh,28px);font-family:var(--font-body--family);font-size:var(--nb-home-hero-type-overline);font-weight:650;letter-spacing:.18em;text-transform:uppercase;opacity:.68;line-height:1.35;}
#nb-home-hero-{{ section.id }} .nb-home-hero__heading{margin:0;max-width:var(--nb-home-hero-heading-measure);font-family:var(--font-heading--family);font-size:var(--nb-home-hero-type-heading);line-height:.98;letter-spacing:-.035em;font-weight:500;text-wrap:balance;}
#nb-home-hero-{{ section.id }} .nb-home-hero__subheading{max-width:var(--nb-home-hero-copy-measure);margin:clamp(20px,2.4vh,30px) 0 0;font-family:var(--font-body--family);font-size:var(--nb-home-hero-type-subheading);line-height:1.45;opacity:.92;}
#nb-home-hero-{{ section.id }} .nb-home-hero__subheading p{margin:0;}
#nb-home-hero-{{ section.id }} .nb-home-hero__actions{display:flex;gap:22px 28px;align-items:center;flex-wrap:wrap;margin-top:clamp(24px,3vh,34px);}
#nb-home-hero-{{ section.id }} .button{min-height:var(--nb-home-button-h);min-width:min(100%,372px);padding:0 var(--nb-home-button-x);background:var(--nb-home-teal);color:#fff;text-decoration:none;border-radius:3px;font-family:var(--font-body--family);font-size:var(--nb-home-hero-type-button);font-weight:700;letter-spacing:.04em;}
#nb-home-hero-{{ section.id }} .button:hover{background:var(--nb-home-teal-dark);}
#nb-home-hero-{{ section.id }} .nb-home-hero__secondary{font-family:var(--font-body--family);color:currentColor;text-underline-offset:8px;text-decoration-thickness:1px;text-decoration-color:rgba(20,117,124,.75);font-size:var(--nb-home-hero-type-button);font-weight:450;opacity:.9;}
#nb-home-hero-{{ section.id }} .nb-home-hero__microcopy{margin:clamp(16px,2vh,24px) 0 0;max-width:var(--nb-home-hero-copy-measure);font-family:var(--font-heading--family);font-style:italic;font-size:var(--nb-home-hero-type-microcopy);line-height:1.45;opacity:.62;}
#nb-home-hero-{{ section.id }} .nb-home-hero__media{position:relative;min-height:100%;overflow:hidden;background:linear-gradient(135deg,rgba(20,117,124,.08),rgba(233,232,222,.38));}
#nb-home-hero-{{ section.id }} .nb-home-hero__media::before{content:"";position:absolute;inset:0 auto 0 0;width:clamp(72px,8vw,150px);pointer-events:none;background:linear-gradient(90deg,var(--nb-home-cream) 0%,rgba(233,232,222,.78) 22%,rgba(233,232,222,.34) 58%,rgba(233,232,222,0) 100%);z-index:1;}
#nb-home-hero-{{ section.id }} .nb-home-hero__media::after{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(90deg,rgba(233,232,222,.12),rgba(20,117,124,.04));mix-blend-mode:multiply;}
#nb-home-hero-{{ section.id }} .nb-home-hero__image{display:block;width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.image_position }};transform:scale(1.04);}
@media(min-width:990px){#nb-home-hero-{{ section.id }}{padding-top:var(--nb-home-header-offset);}#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{height:clamp(620px,calc(92svh - var(--nb-home-header-offset)),820px);min-height:0;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{padding-top:0;background-clip:border-box;min-height:0;height:100%;}#nb-home-hero-{{ section.id }} .nb-home-hero__media::before,#nb-home-hero-{{ section.id }} .nb-home-hero__media::after{top:0;}#nb-home-hero-{{ section.id }} .nb-home-hero__image{height:100%;min-height:0;transform:scale(1.06);transform-origin:center;}}
@media(min-width:1600px) and (min-height:900px){#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{height:clamp(760px,calc(88svh - var(--nb-home-header-offset)),980px);}#nb-home-hero-{{ section.id }} .nb-home-hero__image{transform:scale(1.02);}}
@media(max-width:989px){#nb-home-hero-{{ section.id }}{--nb-home-hero-copy-measure:100%;--nb-home-hero-heading-measure:100%;}#nb-home-hero-{{ section.id }} .nb-home-hero__wrap{grid-template-columns:1fr;min-height:0;}#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:72px 32px 54px;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:440px;order:2;}#nb-home-hero-{{ section.id }} .nb-home-hero__media::before{inset:0 0 auto;height:1px;width:auto;box-shadow:0 -18px 36px rgba(40,49,59,.08);}}
@media(max-width:749px){#nb-home-hero-{{ section.id }}{--nb-home-hero-type-heading:clamp(46px,14vw,64px);--nb-home-button-h:64px;}#nb-home-hero-{{ section.id }} .nb-home-hero__copy{padding:58px 22px 44px;}#nb-home-hero-{{ section.id }} .nb-home-hero__actions{align-items:stretch;flex-direction:column;}#nb-home-hero-{{ section.id }} .button{min-width:0;width:100%;justify-content:center;}#nb-home-hero-{{ section.id }} .nb-home-hero__media{min-height:340px;}}
{% endstyle %}
{% schema %}
{
  "name": "NB — Home hero",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center top",
          "label": "Top"
        },
        {
          "value": "center 35%",
          "label": "Upper centre"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NB — Home hero"
    }
  ]
}
{% endschema %}
