{%- comment -%}
  NB — Rich Text
  General-purpose rich text section for pillar pages and long-form content.
  Supports: heading (H2), rich-text body (with bullets, inline links, bold),
  optional panel background, optional floating card container.
{%- endcomment -%}

{%- liquid
  assign heading    = section.settings.heading | default: ''
  assign body       = section.settings.body
  assign panel_on   = section.settings.panel_on
  assign panel_col  = section.settings.panel_color | default: '#F3FAF8'
  assign max_w      = section.settings.max_width | default: 'normal'
  assign card_on    = section.settings.card_on
  assign card_bg    = section.settings.card_bg | default: '#ffffff'
  assign tone       = section.settings.tone | default: 'scheme'
  assign style_mode = section.settings.style_mode | default: 'default'
-%}

<section
  id="nb-rt-{{ section.id }}"
  class="nb-rt color-{{ section.settings.color_scheme }} {% if panel_on %}nb-rt--panel{% endif %} {% if card_on %}nb-rt--card{% endif %} nb-rt--align-{{ section.settings.alignment }} {% if section.settings.editorial_text %}nb-rt--editorial{% endif %} nb-rt--tone-{{ tone }} nb-rt--style-{{ style_mode }}"
  style="
    --nb-rt-panel: {{ panel_col }};
    --nb-rt-card-bg: {{ card_bg }};
    padding-block-start: {{ section.settings.pad_top }}px;
    padding-block-end: {{ section.settings.pad_bottom }}px;
  "
>
  <div class="nb-rt__shell nb-rt__shell--{{ max_w }}">
    {%- if heading != blank -%}
      <h2 class="nb-rt__heading">{{ heading }}</h2>
    {%- endif -%}

    {%- if body != blank -%}
      <div class="nb-rte nb-rt__body">
        {{ body }}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* Floating card container (class-based, no Liquid conditionals in CSS) */
  .nb-rt--card .nb-rt__shell{
    max-width: min(1160px, 94vw);
    background: var(--nb-rt-card-bg, #fff);
    border-radius: 20px;
    box-shadow: 0 10px 28px rgba(0,0,0,.06);
  }
</style>

{% style %}
  #nb-rt-{{ section.id }}{
    --nb-home-ink:#223238;--nb-home-cream:#f7f1e8;--nb-home-teal:#10636c;
    background: {% if panel_on %}var(--nb-rt-panel, var(--nb-mist, #F3FAF8)){% else %}rgb(var(--color-background)){% endif %};
    color: rgb(var(--color-foreground));
  }
  #nb-rt-{{ section.id }}.nb-rt--tone-dark{
    background:#223238;
    color:#f7f1e8;
  }
  #nb-rt-{{ section.id }}.nb-rt--tone-sage{
    background:#e8eee8;
    color:#223238;
  }

  #nb-rt-{{ section.id }} .nb-rt__shell{
    margin: 0 auto;
    padding: clamp(24px, 3vw, 48px) clamp(20px, 4vw, 40px);
  }
  #nb-rt-{{ section.id }} .nb-rt__shell--narrow{ max-width: 720px; }
  #nb-rt-{{ section.id }} .nb-rt__shell--normal{ max-width: 900px; }
  #nb-rt-{{ section.id }} .nb-rt__shell--wide{ max-width: 1120px; }

  #nb-rt-{{ section.id }} .nb-rt__heading{
    color: currentColor;
    font-family:var(--font-heading--family);
    font-size:var(--nb-home-type-section-heading);
    line-height:1.03;
    font-weight:500;
    letter-spacing: -0.032em;
    text-wrap: balance;
    margin: 0 0 0.75em;
  }

  #nb-rt-{{ section.id }} .nb-rt__body{
    color: currentColor;
    line-height: 1.72;
    font-size: var(--nb-home-type-body);
  }
  #nb-rt-{{ section.id }} .nb-rt__body p{
    margin: 0 0 1em;
  }
  #nb-rt-{{ section.id }} .nb-rt__body p:last-child{
    margin-bottom: 0;
  }
  #nb-rt-{{ section.id }}.nb-rt--align-center .nb-rt__shell{ text-align:center; }
  #nb-rt-{{ section.id }}.nb-rt--align-left .nb-rt__shell{ text-align:left; }
  #nb-rt-{{ section.id }}.nb-rt--editorial .nb-rt__body{ font-size:var(--nb-home-type-editorial-body); line-height:1.62; letter-spacing:-.01em; }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition{
    --nb-home-ink:#202f34;
    --nb-home-cream:#f3eadc;
    --nb-home-sage:#a9bca8;
    background:var(--nb-home-ink);
    color:var(--nb-home-cream);
    padding-block-start:0!important;
    padding-block-end:0!important;
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__shell{
    max-width:1040px;
    margin-inline:auto;
    padding:clamp(92px,10vw,156px) clamp(26px,5vw,64px);
    text-align:left;
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body{
    max-width:23em;
    color:currentColor;
    font-family:var(--font-heading--family);
    /* Recognition intentionally honors the Theme Editor desktop value exactly;
       mobile gets a separate override below to prevent awkward wrapping. */
    font-size:{{ settings.nb_home_editorial_body_font_size | default: 34 }}px;
    font-weight:500;
    letter-spacing:-.018em;
    line-height:1.34;
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body p{
    max-width:none;
    font-size:inherit;
    line-height:inherit;
    letter-spacing:inherit;
    margin:0 0 clamp(18px,2vw,28px);
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body p:nth-child(4){
    color:rgba(243,234,220,.84);
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body p:last-child{
    margin-top:clamp(24px,3vw,38px);
    margin-bottom:0;
    color:var(--nb-home-sage);
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body p:last-child::before{
    content:"";
    display:block;
    width:min(220px,46vw);
    height:1px;
    margin:0 0 clamp(20px,2.2vw,30px);
    background:rgba(243,234,220,.22);
  }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body em{
    color:inherit;
    font-style:italic;
  }
  #nb-rt-{{ section.id }}.nb-rt--tone-dark .nb-rt__shell{ padding-block:clamp(30px,4vw,56px); }
  #nb-rt-{{ section.id }}.nb-rt--tone-dark.nb-rt--style-recognition .nb-rt__shell{ padding:clamp(92px,10vw,156px) clamp(26px,5vw,64px); }
  #nb-rt-{{ section.id }}.nb-rt--tone-dark .nb-rt__body em{ color:#f2ded0; }
  #nb-rt-{{ section.id }}.nb-rt--tone-dark.nb-rt--style-recognition .nb-rt__body em{ color:inherit; }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body hr{border-color:rgba(247,241,232,.16);}
  #nb-rt-{{ section.id }}.nb-rt--editorial .nb-rt__body p + p{ margin-top:1.15em; }
  #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body p + p{ margin-top:0; }
  #nb-rt-{{ section.id }}.nb-rt--editorial .nb-rt__body hr{ border:0; border-top:1px solid rgba(var(--color-foreground),.18); margin:2.2em 0 1.4em; }


  @media (max-width: 749px){
    #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__shell{
      max-width:none;
      margin-left:0;
      padding:clamp(72px,18vw,96px) clamp(22px,7vw,34px);
    }
    #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body{
      max-width:100%;
      font-size:clamp(24px,7.2vw,31px);
      line-height:1.38;
      letter-spacing:-.012em;
    }
    #nb-rt-{{ section.id }}.nb-rt--style-recognition .nb-rt__body p{
      margin-bottom:clamp(18px,5vw,26px);
    }
  }

  /* Bullet lists */
  #nb-rt-{{ section.id }} .nb-rt__body ul{
    padding-left: 0;
    list-style: none;
    margin: 0.75em 0;
  }
  #nb-rt-{{ section.id }} .nb-rt__body ul li{
    position: relative;
    padding-left: 1.5em;
    margin-bottom: 0.6em;
  }
  #nb-rt-{{ section.id }} .nb-rt__body ul li::before{
    content: "—";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--nb-teal, #10636c);
    font-weight: 700;
  }

  /* Inline links */
  #nb-rt-{{ section.id }} .nb-rt__body a{
    color: var(--nb-teal, #10636c);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  #nb-rt-{{ section.id }} .nb-rt__body a:hover{
    color: var(--nb-deep, #0F5B59);
  }

  /* Bold text */
  #nb-rt-{{ section.id }} .nb-rt__body strong{
    color: currentColor;
    font-weight: 700;
  }
{% endstyle %}

{% schema %}
{
  "name": "NB — Rich Text",
  "tag": "section",
  "class": "nb-rich-text-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Homepage tone fallback",
      "default": "scheme",
      "options": [
        { "value": "scheme", "label": "Use color scheme" },
        { "value": "dark", "label": "Dark slate" },
        { "value": "sage", "label": "Pale sage" }
      ]
    },
    {
      "type": "select",
      "id": "style_mode",
      "label": "Style mode",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "recognition", "label": "Homepage recognition" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "editorial_text",
      "label": "Use large editorial body text",
      "default": false
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Content width",
      "default": "normal",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow (720px)"
        },
        {
          "value": "normal",
          "label": "Normal (900px)"
        },
        {
          "value": "wide",
          "label": "Wide (1120px)"
        }
      ]
    },
    {
      "type": "header",
      "content": "Floating card container"
    },
    {
      "type": "checkbox",
      "id": "card_on",
      "label": "Wrap in floating card",
      "default": false
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Panel background"
    },
    {
      "type": "checkbox",
      "id": "panel_on",
      "label": "Show panel background",
      "default": false
    },
    {
      "type": "color",
      "id": "panel_color",
      "label": "Panel background color",
      "default": "#F3FAF8"
    },
    {
      "type": "range",
      "id": "pad_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "NB — Rich Text",
      "category": "Text"
    }
  ]
}
{% endschema %}
