{%- comment -%}
  NB — Rich Text
  General-purpose rich text section for pillar pages and long-form content.
  Supports: heading (H2), rich-text body (with bullets, inline links, bold), optional panel background.
{%- endcomment -%}

{%- liquid
  assign heading    = section.settings.heading | default: ''
  assign body       = section.settings.body
  assign panel_on   = section.settings.panel_on
  assign panel_col  = section.settings.panel_color | default: '#F3FAF8'
  assign max_w      = section.settings.max_width | default: 'normal'
-%}

<section
  id="nb-rt-{{ section.id }}"
  class="nb-rt {% if panel_on %}nb-rt--panel{% endif %}"
  style="
    --nb-rt-panel: {{ panel_col }};
    padding-block-start: {{ section.settings.pad_top }}px;
    padding-block-end: {{ section.settings.pad_bottom }}px;
  "
>
  <div class="nb-rt__shell nb-rt__shell--{{ max_w }}">
    {%- if heading != blank -%}
      <h2 class="nb-rt__heading">{{ heading }}</h2>
    {%- endif -%}

    {%- if body != blank -%}
      <div class="nb-rte nb-rt__body">
        {{ body }}
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  #nb-rt-{{ section.id }}{
    background: {% if panel_on %}var(--nb-rt-panel, var(--nb-mist, #F3FAF8)){% else %}transparent{% endif %};
  }

  #nb-rt-{{ section.id }} .nb-rt__shell{
    margin: 0 auto;
    padding: clamp(24px, 3vw, 48px) clamp(20px, 4vw, 40px);
  }
  #nb-rt-{{ section.id }} .nb-rt__shell--narrow{ max-width: 720px; }
  #nb-rt-{{ section.id }} .nb-rt__shell--normal{ max-width: 900px; }
  #nb-rt-{{ section.id }} .nb-rt__shell--wide{ max-width: 1120px; }

  #nb-rt-{{ section.id }} .nb-rt__heading{
    color: var(--nb-teal, #10636c);
    font-weight: 800;
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin: 0 0 0.75em;
  }

  #nb-rt-{{ section.id }} .nb-rt__body{
    color: var(--nb-ink, #223238);
    line-height: 1.72;
    font-size: 1.05rem;
  }
  #nb-rt-{{ section.id }} .nb-rt__body p{
    margin: 0 0 1em;
  }
  #nb-rt-{{ section.id }} .nb-rt__body p:last-child{
    margin-bottom: 0;
  }

  /* Bullet lists */
  #nb-rt-{{ section.id }} .nb-rt__body ul{
    padding-left: 0;
    list-style: none;
    margin: 0.75em 0;
  }
  #nb-rt-{{ section.id }} .nb-rt__body ul li{
    position: relative;
    padding-left: 1.5em;
    margin-bottom: 0.6em;
  }
  #nb-rt-{{ section.id }} .nb-rt__body ul li::before{
    content: "—";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--nb-teal, #10636c);
    font-weight: 700;
  }

  /* Inline links */
  #nb-rt-{{ section.id }} .nb-rt__body a{
    color: var(--nb-teal, #10636c);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  #nb-rt-{{ section.id }} .nb-rt__body a:hover{
    color: var(--nb-deep, #0F5B59);
  }

  /* Bold text */
  #nb-rt-{{ section.id }} .nb-rt__body strong{
    color: var(--nb-ink, #223238);
    font-weight: 700;
  }
{% endstyle %}

{% schema %}
{
  "name": "NB — Rich Text",
  "tag": "section",
  "class": "nb-rich-text-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body", "label": "Body" },

    { "type": "select", "id": "max_width", "label": "Content width", "default": "normal",
      "options": [
        { "value": "narrow", "label": "Narrow (720px)" },
        { "value": "normal", "label": "Normal (900px)" },
        { "value": "wide",   "label": "Wide (1120px)" }
      ]
    },

    { "type": "checkbox", "id": "panel_on", "label": "Show panel background", "default": false },
    { "type": "color", "id": "panel_color", "label": "Panel background color", "default": "#F3FAF8" },

    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "pad_bottom", "label": "Bottom padding", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "NB — Rich Text", "category": "Text" }
  ]
}
{% endschema %}
