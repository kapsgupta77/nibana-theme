{%- comment -%}
  NB — P2P Hero
  Split-layout hero: text on the left, portrait image on the right.
  Matches the home page visual style (teal heading, orange CTA, serif font).
{%- endcomment -%}

{%- liquid
  assign title       = section.settings.title | default: ''
  assign subtitle    = section.settings.subtitle | default: ''
  assign description = section.settings.description | default: ''
  assign btn_text    = section.settings.button_text | default: ''
  assign btn_url     = section.settings.button_url | default: ''
  assign img         = section.settings.image
-%}

<section id="nb-p2p-hero-{{ section.id }}" class="nb-p2p-hero">
  <div class="nb-p2p-hero__row">
    <div class="nb-p2p-hero__text">
      {%- if title != blank -%}
        <h1 class="nb-p2p-hero__title">{{ title }}</h1>
      {%- endif -%}

      {%- if subtitle != blank -%}
        <p class="nb-p2p-hero__subtitle">{{ subtitle }}</p>
      {%- endif -%}

      {%- if description != blank -%}
        <p class="nb-p2p-hero__desc">{{ description }}</p>
      {%- endif -%}

      {%- if btn_text != blank and btn_url != blank -%}
        <a class="nb-p2p-hero__cta" href="{{ btn_url }}">{{ btn_text }}</a>
      {%- endif -%}
    </div>

    <div class="nb-p2p-hero__media">
      {%- if img != blank -%}
        <img
          src="{{ img | image_url: width: 1200 }}"
          alt="{{ img.alt | default: title | escape }}"
          loading="eager"
          width="{{ img.width }}"
          height="{{ img.height }}"
          class="nb-p2p-hero__img"
        >
      {%- else -%}
        <div class="nb-p2p-hero__placeholder">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .nb-p2p-hero{
    background: #f5f6f4;
    overflow: hidden;
  }

  .nb-p2p-hero__row{
    display: flex;
    align-items: stretch;
    min-height: 560px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .nb-p2p-hero__text{
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(32px, 5vw, 80px) clamp(24px, 4vw, 64px);
  }

  .nb-p2p-hero__title{
    font-family: var(--font-heading--family, 'Cormorant', serif);
    font-size: clamp(36px, 4.5vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.5px;
    color: #0E6A6F;
    margin: 0 0 16px;
  }

  .nb-p2p-hero__subtitle{
    font-family: var(--font-body--family, 'Inter', sans-serif);
    font-size: clamp(16px, 1.6vw, 20px);
    font-weight: 400;
    line-height: 1.5;
    color: #2f3e48;
    margin: 0 0 12px;
  }

  .nb-p2p-hero__desc{
    font-family: var(--font-body--family, 'Inter', sans-serif);
    font-size: clamp(14px, 1.2vw, 16px);
    font-weight: 500;
    font-style: italic;
    line-height: 1.5;
    color: rgba(47, 62, 72, 0.75);
    margin: 0 0 24px;
  }

  .nb-p2p-hero__cta{
    display: inline-block;
    padding: 14px 28px;
    background-color: #d16c28;
    color: #ffffff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 17px;
    font-weight: 600;
    border: none;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }
  .nb-p2p-hero__cta:hover{
    background-color: #b85f23;
  }

  .nb-p2p-hero__media{
    flex: 0 0 55%;
    position: relative;
    overflow: hidden;
  }

  .nb-p2p-hero__img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .nb-p2p-hero__placeholder{
    width: 100%;
    height: 100%;
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nb-p2p-hero__placeholder svg{
    max-width: 200px;
    opacity: 0.3;
  }

  /* Tablet */
  @media (max-width: 1024px){
    .nb-p2p-hero__row{
      min-height: 450px;
    }
    .nb-p2p-hero__text{
      flex: 0 0 50%;
    }
    .nb-p2p-hero__media{
      flex: 0 0 50%;
    }
  }

  /* Mobile */
  @media (max-width: 749px){
    .nb-p2p-hero__row{
      flex-direction: column-reverse;
      min-height: auto;
    }
    .nb-p2p-hero__text{
      flex: none;
      padding: 28px 20px 36px;
    }
    .nb-p2p-hero__media{
      flex: none;
      height: 320px;
    }
    .nb-p2p-hero__cta{
      align-self: stretch;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "NB — P2P Hero",
  "tag": "section",
  "class": "nb-p2p-hero-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Portrait image" },
    { "type": "text", "id": "title", "label": "Heading", "default": "The Performance to Presence Method" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    { "type": "textarea", "id": "description", "label": "Description (italic)" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Book a private conversation" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [
    { "name": "NB — P2P Hero" }
  ]
}
{% endschema %}
