{% comment %}
  Media & Press -- TEDx Talk (Featured, prominent)
  YouTube embed with title, description, and view count badge.
  Two-column layout: video + text. Most prominent section on the page.
{% endcomment %}

<section
  id="nb-media-tedx-{{ section.id }}"
  class="nb-media-tedx {{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings.pad_top }}px; padding-block-end: {{ section.settings.pad_bottom }}px;"
>
  <div class="nb-shell">
    <div
      class="nb-media-tedx__wrap"
      {% if section.settings.panel_on %}style="--nb-panel-bg: {{ section.settings.panel_color | default: '#F3FAF8' }};"{% endif %}
    >
      <div class="nb-media-tedx__video">
        <div class="nb-media-tedx__embed">
          <iframe
            src="https://www.youtube.com/embed/{{ section.settings.youtube_id }}"
            title="{{ section.settings.heading | escape }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
      </div>

      <div class="nb-media-tedx__content">
        {% if section.settings.kicker != blank %}
          <p class="nb-kicker">{{ section.settings.kicker }}</p>
        {% endif %}

        <h2 class="nb-h2 nb-media-tedx__title">{{ section.settings.heading }}</h2>

        {% if section.settings.subheading != blank %}
          <p class="nb-media-tedx__sub">{{ section.settings.subheading }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="nb-rte nb-media-tedx__desc">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.views_badge != blank %}
          <span class="nb-media-tedx__badge">{{ section.settings.views_badge }}</span>
        {% endif %}
      </div>
    </div>
  </div>

  <style>
    .nb-media-tedx .nb-media-tedx__wrap {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      background: {% if section.settings.panel_on %}var(--nb-panel-bg, var(--nb-mist, #F3FAF8)){% else %}transparent{% endif %};
      border-radius: 20px;
      padding: clamp(20px, 3vw, 36px);
      box-shadow: {% if section.settings.panel_on %}0 10px 28px rgba(12,138,123,.08), 0 1px 0 rgba(255,255,255,.8) inset{% else %}none{% endif %};
    }

    @media (min-width: 980px) {
      .nb-media-tedx .nb-media-tedx__wrap {
        grid-template-columns: 1.3fr 1fr;
      }
    }

    .nb-media-tedx__embed {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      overflow: hidden;
      border-radius: 20px;
      box-shadow: 0 12px 32px rgba(0,0,0,.10);
    }

    .nb-media-tedx__embed iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
      border-radius: 20px;
    }

    .nb-media-tedx__title {
      margin: 0 0 6px;
    }

    .nb-media-tedx__sub {
      font-size: clamp(14px, 1.1vw, 16px);
      font-weight: 600;
      color: var(--nb-teal, #10636c);
      margin: 0 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .nb-media-tedx__desc {
      margin: 0 0 14px;
      opacity: .92;
      line-height: 1.6;
    }

    .nb-media-tedx__badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--nb-teal, #10636c);
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 9999px;
      letter-spacing: 0.02em;
    }

    .nb-media-tedx .nb-kicker {
      margin: 0 0 8px;
      opacity: .85;
    }
  </style>
</section>

{% schema %}
{
  "name": "Media -- TEDx Talk",
  "class": "section-wrapper nb-media-tedx-wrap",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Featured Talk" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Kapil's TEDx Talk: \"Dare To Be Sensitive\"" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "TEDx Lambeth" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>In this thought-provoking talk, Kapil speaks about how most men are socially conditioned from a young age to hide their emotions and see their vulnerability and sensitivity as weakness, and the impact this has on their lives and personal relationships.</p>" },
    { "type": "text", "id": "youtube_id", "label": "YouTube Video ID", "default": "sdTy9IZR87k" },
    { "type": "text", "id": "views_badge", "label": "Views badge text", "default": "136,000+ views" },
    { "type": "checkbox", "id": "panel_on", "label": "Show panel background", "default": true },
    { "type": "color", "id": "panel_color", "label": "Panel background color", "default": "#F3FAF8" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "pad_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "Media -- TEDx Talk" }
  ]
}
{% endschema %}
