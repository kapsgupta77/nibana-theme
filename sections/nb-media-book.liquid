{% comment %}
  Media & Press -- Published Author / Book section
  Features "Being FINE: The Other F Word" with description and Amazon link.
  Supports an optional book cover image uploaded via Shopify admin.
{% endcomment %}

<section
  id="nb-media-book-{{ section.id }}"
  class="nb-media-book {{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings.pad_top }}px; padding-block-end: {{ section.settings.pad_bottom }}px;"
>
  <div class="nb-shell">
    <div
      class="nb-media-book__wrap"
      {% if section.settings.panel_on %}style="--nb-panel-bg: {{ section.settings.panel_color | default: '#F3FAF8' }};"{% endif %}
    >
      {% if section.settings.image != blank %}
        <div class="nb-media-book__media">
          {{ section.settings.image | image_url: width: 400 | image_tag: class: 'nb-media-book__img', alt: section.settings.image_alt | escape }}
        </div>
      {% endif %}

      <div class="nb-media-book__content">
        {% if section.settings.kicker != blank %}
          <p class="nb-kicker">{{ section.settings.kicker }}</p>
        {% endif %}

        <h2 class="nb-h2 nb-media-book__title">{{ section.settings.heading }}</h2>

        {% if section.settings.author_note != blank %}
          <p class="nb-media-book__author">{{ section.settings.author_note }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="nb-rte nb-media-book__desc">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
          <div class="nb-media-book__actions">
            <a class="nb-cta nb-cta--xl" href="{{ section.settings.cta_link }}" target="_blank" rel="noopener" data-cta="media-book-cta">
              {{ section.settings.cta_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <style>
    .nb-media-book .nb-media-book__wrap {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      background: {% if section.settings.panel_on %}var(--nb-panel-bg, var(--nb-mist, #F3FAF8)){% else %}transparent{% endif %};
      border-radius: 20px;
      padding: clamp(22px, 3vw, 40px);
      box-shadow: {% if section.settings.panel_on %}0 10px 28px rgba(12,138,123,.08), 0 1px 0 rgba(255,255,255,.8) inset{% else %}none{% endif %};
    }

    @media (min-width: 980px) {
      .nb-media-book .nb-media-book__wrap {
        grid-template-columns: auto 1fr;
      }
    }

    .nb-media-book__media {
      text-align: center;
    }

    .nb-media-book__img {
      max-width: 220px;
      width: 100%;
      height: auto;
      border-radius: 12px;
      box-shadow: 0 12px 32px rgba(0,0,0,.12);
    }

    .nb-media-book .nb-kicker {
      margin: 0 0 8px;
      opacity: .85;
    }

    .nb-media-book__title {
      margin: 0 0 6px;
    }

    .nb-media-book__author {
      font-size: clamp(13px, 1vw, 15px);
      font-weight: 600;
      color: var(--nb-teal, #10636c);
      margin: 0 0 10px;
    }

    .nb-media-book__desc {
      margin: 0 0 16px;
      opacity: .92;
      line-height: 1.6;
      max-width: 560px;
    }

    .nb-media-book__actions {
      margin-top: 6px;
    }

    /* When no image, center the content */
    .nb-media-book .nb-media-book__wrap:only-child .nb-media-book__content {
      text-align: center;
    }
  </style>
</section>

{% schema %}
{
  "name": "Media -- Book",
  "class": "section-wrapper nb-media-book-wrap",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Published Author" },
    { "type": "text", "id": "heading", "label": "Book title", "default": "Being FINE: The Other F Word" },
    { "type": "text", "id": "author_note", "label": "Author note", "default": "Co-authored by Kapil Gupta" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>A powerful exploration of what lies beneath the surface when we say we're \"fine.\" This book challenges readers to look beyond the mask and discover what happens when we dare to be honest about how we really feel.</p>" },
    { "type": "image_picker", "id": "image", "label": "Book cover image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Being FINE: The Other F Word book cover" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View on Amazon" },
    { "type": "text", "id": "cta_link", "label": "CTA link", "default": "https://www.amazon.co.uk/Being-FINE-Other-F-Word/dp/1838335900" },
    { "type": "checkbox", "id": "panel_on", "label": "Show panel background", "default": true },
    { "type": "color", "id": "panel_color", "label": "Panel background color", "default": "#F3FAF8" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "pad_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "Media -- Book" }
  ]
}
{% endschema %}
