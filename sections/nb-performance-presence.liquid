<section id="nb-pp-{{ section.id }}" class="nb-pp color-{{ section.settings.color_scheme }} nb-pp--tone-{{ section.settings.tone }}">
  <div class="nb-pp__wrap">
    {% if section.settings.overline != blank %}<p class="nb-pp__overline">{{ section.settings.overline }}</p>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    <div class="nb-pp__body">{{ section.settings.body }}</div>
    <div class="nb-pp__model" role="list">
      {% for block in section.blocks %}<article class="nb-pp__stage" role="listitem" {{ block.shopify_attributes }}><span class="nb-pp__dot"></span><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></article>{% endfor %}
    </div>
    {% if section.settings.bridge != blank %}<p class="nb-pp__bridge">{{ section.settings.bridge }}</p>{% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}<a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>{% endif %}
  </div>
</section>
{% style %}
#nb-pp-{{ section.id }}{--nb-home-ink:#223238;--nb-home-teal:#10636c;background:rgb(var(--color-background));color:rgb(var(--color-foreground));padding:clamp(92px,9.5vw,140px) 20px;}
#nb-pp-{{ section.id }}.nb-pp--tone-sage{background:#e4ebe4;color:var(--nb-home-ink);}
#nb-pp-{{ section.id }} .nb-pp__wrap{max-width:1160px;margin:0 auto;}
#nb-pp-{{ section.id }} .nb-pp__overline{margin:0 0 10px;font-size:var(--nb-home-type-overline);letter-spacing:.13em;text-transform:uppercase;opacity:.64;line-height:1.35;}
#nb-pp-{{ section.id }} h2{margin:0 0 20px;font-family:var(--font-heading--family);font-size:var(--nb-home-type-section-heading);line-height:1.03;letter-spacing:-.032em;font-weight:500;}
#nb-pp-{{ section.id }} .nb-pp__body{max-width:66ch;font-size:var(--nb-home-type-body);line-height:1.7;}
#nb-pp-{{ section.id }} .nb-pp__body p{margin:0 0 1em;}
#nb-pp-{{ section.id }} .nb-pp__model{position:relative;display:grid;grid-template-columns:repeat({{ section.blocks.size | at_least: 1 }},1fr);gap:0;margin:clamp(62px,7vw,92px) 0 34px;border-top:1px solid rgba(var(--color-foreground),.22);border-bottom:1px solid rgba(var(--color-foreground),.22);}
#nb-pp-{{ section.id }} .nb-pp__model:before{content:"";position:absolute;left:clamp(22px,2.4vw,30px);right:clamp(22px,2.4vw,30px);top:30px;height:1px;background:rgba(var(--color-foreground),.24);}
#nb-pp-{{ section.id }} .nb-pp__stage{position:relative;padding:72px clamp(18px,2.3vw,34px) clamp(34px,3.2vw,44px);}
#nb-pp-{{ section.id }} .nb-pp__stage + .nb-pp__stage{border-left:1px solid rgba(var(--color-foreground),.16);}
#nb-pp-{{ section.id }} .nb-pp__dot{position:absolute;left:clamp(16px,2vw,28px);top:23px;width:15px;height:15px;border-radius:50%;background:var(--nb-home-teal);box-shadow:0 0 0 9px #e4ebe4;}
#nb-pp-{{ section.id }} h3{margin:0 0 10px;font-size:var(--nb-home-type-overline);letter-spacing:.08em;text-transform:uppercase;font-weight:800;}
#nb-pp-{{ section.id }} .nb-pp__stage p{margin:0;font-size:var(--nb-home-type-microcopy);line-height:1.58;opacity:.82;}
#nb-pp-{{ section.id }} .nb-pp__bridge{max-width:72ch;margin:34px 0 0;font-size:var(--nb-home-type-microcopy);line-height:1.62;opacity:.74;}
#nb-pp-{{ section.id }} .button{min-height:48px;padding:0 24px;border-radius:999px;margin-top:26px;background:var(--nb-home-teal);color:#fff;font-size:var(--nb-home-type-button);font-weight:700;}
@media(max-width:749px){#nb-pp-{{ section.id }} .nb-pp__model{display:block;margin-top:40px;border:0;background:transparent;}#nb-pp-{{ section.id }} .nb-pp__model:before{left:8px;right:auto;top:0;bottom:0;width:1px;height:auto;}#nb-pp-{{ section.id }} .nb-pp__stage,#nb-pp-{{ section.id }} .nb-pp__stage + .nb-pp__stage{padding:0 0 32px 38px;border-left:0;}#nb-pp-{{ section.id }} .nb-pp__dot{left:0;top:2px;width:15px;height:15px;} }
{% endstyle %}
{% schema %}
{
  "name": "NB — Performance Presence",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Homepage tone fallback",
      "default": "sage",
      "options": [
        { "value": "scheme", "label": "Use color scheme" },
        { "value": "sage", "label": "Pale sage" }
      ]
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "The Method"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    },
    {
      "type": "text",
      "id": "bridge",
      "label": "Bridge line"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Optional CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Optional CTA link"
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descriptor"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "NB — Performance to Presence"
    }
  ]
}
{% endschema %}
