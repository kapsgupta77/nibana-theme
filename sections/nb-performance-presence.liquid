<section id="nb-pp-{{ section.id }}" class="nb-pp color-{{ section.settings.color_scheme }} nb-pp--tone-{{ section.settings.tone }}">
  <div class="nb-pp__wrap">
    {% if section.settings.overline != blank %}<p class="nb-pp__overline">{{ section.settings.overline }}</p>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    <div class="nb-pp__body">{{ section.settings.body }}</div>
    <div class="nb-pp__method-card">
      <div class="nb-pp__model" role="list" style="--nb-pp-stage-count: {{ section.blocks.size | at_least: 1 }};">
        {% for block in section.blocks %}
          <article class="nb-pp__stage{% if forloop.last %} nb-pp__stage--arrival{% endif %}" role="listitem" {{ block.shopify_attributes }}>
            <span class="nb-pp__index">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <span class="nb-pp__dot" aria-hidden="true"></span>
            <div class="nb-pp__stage-copy">
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
      {% if section.settings.bridge != blank %}<p class="nb-pp__bridge">{{ section.settings.bridge }}</p>{% endif %}
      <div class="nb-pp__actions">
        {% if section.settings.secondary_cta_label != blank and section.settings.secondary_cta_link != blank %}<a class="nb-pp__text-link" href="{{ section.settings.secondary_cta_link }}">{{ section.settings.secondary_cta_label }}</a>{% endif %}
        {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}<a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>{% endif %}
      </div>
    </div>
  </div>
</section>
{% style %}
#nb-pp-{{ section.id }}{--nb-home-ink:#223238;--nb-home-teal:#10636c;--nb-pp-sage:#e4ebe4;--nb-pp-cream:var(--nb-home-cream,#e9e8de);--nb-pp-mist:var(--nb-mist,#F3FAF8);--nb-pp-border:rgba(34,50,56,.12);background:var(--color-background);color:var(--color-foreground);padding:clamp(92px,9.5vw,140px) 20px;}
#nb-pp-{{ section.id }}.nb-pp--tone-sage{background:var(--nb-pp-sage);color:var(--nb-home-ink);}
#nb-pp-{{ section.id }} .nb-pp__wrap{max-width:1160px;margin:0 auto;}
#nb-pp-{{ section.id }} .nb-pp__overline{margin:0 0 12px;font-family:var(--font-body--family);font-size:var(--nb-home-type-overline);font-weight:650;letter-spacing:.16em;text-transform:uppercase;opacity:.62;line-height:1.35;}
#nb-pp-{{ section.id }} h2{margin:0 0 24px;font-family:var(--font-heading--family);font-size:clamp(var(--nb-home-type-section-heading),4.3vw,66px);line-height:.98;letter-spacing:-.035em;font-weight:500;}
#nb-pp-{{ section.id }} .nb-pp__body{width:100%;max-width:none;columns:2 28rem;column-gap:clamp(44px,7vw,116px);font-size:var(--nb-home-type-body);line-height:1.7;}
#nb-pp-{{ section.id }} .nb-pp__body p{break-inside:avoid;margin:0 0 1em;}
#nb-pp-{{ section.id }} .nb-pp__method-card{position:relative;margin:clamp(54px,6.2vw,82px) 0 0;padding:clamp(26px,3.2vw,42px);border:1px solid var(--nb-pp-border);border-radius:clamp(22px,2.2vw,30px);background:color-mix(in oklab,var(--nb-pp-mist),var(--nb-pp-cream) 18%);box-shadow:0 18px 46px rgba(34,50,56,.055);overflow:hidden;}
#nb-pp-{{ section.id }} .nb-pp__method-card:before{content:"";position:absolute;inset:14px;border:1px solid rgba(16,99,108,.07);border-radius:calc(clamp(22px,2.2vw,30px) - 7px);pointer-events:none;}
#nb-pp-{{ section.id }} .nb-pp__model{position:relative;display:grid;grid-template-columns:repeat({{ section.blocks.size | at_least: 1 }},minmax(0,1fr));column-gap:clamp(14px,1.45vw,20px);row-gap:0;align-items:stretch;}
#nb-pp-{{ section.id }} .nb-pp__model:before{content:"";position:absolute;left:calc(100% / {{ section.blocks.size | at_least: 1 | times: 2 }});right:calc(100% / {{ section.blocks.size | at_least: 1 | times: 2 }});top:31px;height:1px;background:linear-gradient(90deg,rgba(16,99,108,.08),rgba(16,99,108,.34),rgba(16,99,108,.08));}
#nb-pp-{{ section.id }} .nb-pp__stage{position:relative;display:grid;grid-template-rows:auto auto 1fr;gap:11px;min-height:196px;padding:0;text-align:center;}
#nb-pp-{{ section.id }} .nb-pp__index{font-family:var(--font-body--family);font-size:1rem;font-weight:700;letter-spacing:.18em;line-height:1;text-transform:uppercase;color:rgba(34,50,56,.43);}
#nb-pp-{{ section.id }} .nb-pp__dot{position:relative;justify-self:center;width:11px;height:11px;border:1px solid rgba(16,99,108,.34);border-radius:50%;background:color-mix(in oklab,var(--nb-pp-mist),var(--nb-pp-cream) 18%);box-shadow:0 0 0 8px color-mix(in oklab,var(--nb-pp-mist),var(--nb-pp-cream) 18%);z-index:1;}
#nb-pp-{{ section.id }} .nb-pp__dot:after{content:"";position:absolute;inset:2px;border-radius:50%;background:rgba(16,99,108,.72);}
#nb-pp-{{ section.id }} .nb-pp__stage-copy{height:100%;padding:clamp(15px,1.6vw,20px) clamp(12px,1.25vw,16px);border:1px solid rgba(34,50,56,.09);border-radius:20px;background:rgba(255,255,255,.34);}
#nb-pp-{{ section.id }} h3{margin:0 0 12px;font-family:var(--font-heading--family);font-size:clamp(1.72rem,1.45vw,2.05rem);line-height:1.12;letter-spacing:-.018em;text-transform:none;font-weight:500;}
#nb-pp-{{ section.id }} .nb-pp__stage p{max-width:22ch;margin:0 auto;font-family:var(--font-body--family);font-size:var(--nb-home-type-microcopy);line-height:1.58;opacity:.82;}
#nb-pp-{{ section.id }} .nb-pp__stage--arrival .nb-pp__stage-copy{border-color:rgba(16,99,108,.24);background:rgba(239,246,241,.64);}
#nb-pp-{{ section.id }} .nb-pp__stage--arrival h3{color:var(--nb-home-teal);}
#nb-pp-{{ section.id }} .nb-pp__bridge{position:relative;width:100%;max-width:760px;margin:clamp(24px,2.8vw,34px) auto 0;padding:clamp(16px,1.8vw,22px) clamp(16px,2vw,24px) 0;border-top:1px solid rgba(16,99,108,.18);font-family:var(--font-heading--family);font-size:clamp(1.45rem,1.05vw,1.72rem);font-style:italic;line-height:1.55;text-align:center;color:rgba(34,50,56,.78);}
#nb-pp-{{ section.id }} .nb-pp__actions{display:flex;flex-wrap:wrap;gap:14px;align-items:center;justify-content:center;margin-top:clamp(18px,2.2vw,28px);}
#nb-pp-{{ section.id }} .nb-pp__text-link{display:inline-flex;width:fit-content;align-items:center;justify-content:center;min-height:44px;padding:0 22px;border:1px solid rgb(16 99 108 / .46);border-radius:999px;color:var(--nb-home-teal);font-size:clamp(1.3rem,.84vw,1.45rem);font-weight:650;line-height:1.4;text-align:center;text-decoration:none;transition:border-color .18s ease,color .18s ease,background-color .18s ease,transform .18s ease;}
#nb-pp-{{ section.id }} .nb-pp__text-link:hover,#nb-pp-{{ section.id }} .nb-pp__text-link:focus-visible{border-color:currentColor;background:rgb(16 99 108 / .06);color:#0b4f56;transform:translateY(-1px);}
#nb-pp-{{ section.id }} .button{min-height:46px;padding:0 22px;border-radius:999px;background:var(--nb-home-teal);color:#fff;font-size:var(--nb-home-type-button);font-weight:700;}
@media(max-width:989px){#nb-pp-{{ section.id }} .nb-pp__method-card{padding:clamp(24px,4vw,34px);}#nb-pp-{{ section.id }} .nb-pp__model{grid-template-columns:1fr;}#nb-pp-{{ section.id }} .nb-pp__model:before{left:20px;right:auto;top:12px;bottom:42px;width:1px;height:auto;background:linear-gradient(180deg,rgba(16,99,108,.08),rgba(16,99,108,.34),rgba(16,99,108,.08));}#nb-pp-{{ section.id }} .nb-pp__stage{grid-template-columns:40px 1fr;grid-template-rows:auto 1fr;gap:8px 16px;min-height:0;padding:0 0 clamp(18px,3vw,26px);text-align:left;}#nb-pp-{{ section.id }} .nb-pp__stage:last-child{padding-bottom:0;}#nb-pp-{{ section.id }} .nb-pp__index{grid-column:2;grid-row:1;align-self:end;}#nb-pp-{{ section.id }} .nb-pp__dot{grid-column:1;grid-row:1 / span 2;align-self:start;justify-self:center;margin-top:4px;box-shadow:0 0 0 8px color-mix(in oklab,var(--nb-pp-mist),var(--nb-pp-cream) 18%);}#nb-pp-{{ section.id }} .nb-pp__stage-copy{grid-column:2;grid-row:2;padding:20px;}#nb-pp-{{ section.id }} .nb-pp__stage p{max-width:42rem;margin:0;}}
@media(max-width:749px){#nb-pp-{{ section.id }}{padding:clamp(72px,18vw,96px) 18px;}#nb-pp-{{ section.id }} .nb-pp__body{columns:auto;}#nb-pp-{{ section.id }} .nb-pp__method-card{margin-top:42px;padding:22px 16px;border-radius:22px;}#nb-pp-{{ section.id }} .nb-pp__method-card:before{display:none;}#nb-pp-{{ section.id }} .nb-pp__stage{grid-template-columns:32px 1fr;gap:8px 12px;}#nb-pp-{{ section.id }} .nb-pp__model:before{left:16px;}#nb-pp-{{ section.id }} .nb-pp__stage-copy{border-radius:18px;padding:18px 16px;}#nb-pp-{{ section.id }} .nb-pp__bridge{text-align:left;padding-inline:0;}#nb-pp-{{ section.id }} .nb-pp__actions{justify-content:flex-start;} }
{% endstyle %}
{% schema %}
{
  "name": "NB — Performance Presence",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Homepage tone fallback",
      "default": "sage",
      "options": [
        { "value": "scheme", "label": "Use color scheme" },
        { "value": "sage", "label": "Pale sage" }
      ]
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "The Method"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    },
    {
      "type": "text",
      "id": "bridge",
      "label": "Bridge line"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary text link label"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary text link URL"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Optional CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Optional CTA link"
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descriptor"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "NB — Performance to Presence"
    }
  ]
}
{% endschema %}
