<section id="nb-pp-{{ section.id }}" class="nb-pp color-{{ section.settings.color_scheme }} nb-pp--tone-{{ section.settings.tone }}">
  <div class="nb-pp__wrap">
    {% if section.settings.overline != blank %}<p class="nb-pp__overline">{{ section.settings.overline }}</p>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    <div class="nb-pp__body">{{ section.settings.body }}</div>
    <div class="nb-pp__model" role="list">
      {% for block in section.blocks %}<article class="nb-pp__stage" role="listitem" {{ block.shopify_attributes }}><span class="nb-pp__dot"></span><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></article>{% endfor %}
    </div>
    {% if section.settings.bridge != blank %}<p class="nb-pp__bridge">{{ section.settings.bridge }}</p>{% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}<a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>{% endif %}
  </div>
</section>
{% style %}
#nb-pp-{{ section.id }}{--nb-home-ink:#223238;--nb-home-teal:#10636c;background:rgb(var(--color-background));color:rgb(var(--color-foreground));padding:clamp(92px,9.5vw,140px) 20px;}
#nb-pp-{{ section.id }}.nb-pp--tone-sage{background:#e4ebe4;color:var(--nb-home-ink);}
#nb-pp-{{ section.id }} .nb-pp__wrap{max-width:1160px;margin:0 auto;}
#nb-pp-{{ section.id }} .nb-pp__overline{margin:0 0 10px;font-size:var(--nb-home-type-overline);letter-spacing:.13em;text-transform:uppercase;opacity:.64;line-height:1.35;}
#nb-pp-{{ section.id }} h2{margin:0 0 20px;font-family:var(--font-heading--family);font-size:var(--nb-home-type-section-heading);line-height:1.03;letter-spacing:-.032em;font-weight:500;}
#nb-pp-{{ section.id }} .nb-pp__body{width:100%;max-width:none;columns:2 28rem;column-gap:clamp(44px,7vw,116px);font-size:var(--nb-home-type-body);line-height:1.7;}
#nb-pp-{{ section.id }} .nb-pp__body p{break-inside:avoid;margin:0 0 1em;}
#nb-pp-{{ section.id }} .nb-pp__model{position:relative;display:grid;grid-template-columns:repeat({{ section.blocks.size | at_least: 1 }},minmax(0,1fr));gap:0;margin:clamp(62px,7vw,92px) 0 0;padding-top:54px;}
#nb-pp-{{ section.id }} .nb-pp__model:before{content:"";position:absolute;left:10%;right:10%;top:9px;height:1px;background:rgba(var(--color-foreground),.38);}
#nb-pp-{{ section.id }} .nb-pp__stage{position:relative;padding:0 clamp(16px,2.2vw,30px) clamp(28px,3vw,40px);text-align:center;}
#nb-pp-{{ section.id }} .nb-pp__dot{position:absolute;left:50%;top:-50px;transform:translateX(-50%);width:10px;height:10px;border-radius:50%;background:var(--nb-home-teal);box-shadow:0 0 0 7px rgb(var(--color-background));z-index:1;}
#nb-pp-{{ section.id }}.nb-pp--tone-sage .nb-pp__dot{box-shadow:0 0 0 7px #e4ebe4;}
#nb-pp-{{ section.id }} h3{margin:0 0 12px;font-family:var(--font-heading--family);font-size:clamp(1.7rem,1.55vw,2rem);line-height:1.18;letter-spacing:-.018em;text-transform:none;font-weight:500;}
#nb-pp-{{ section.id }} .nb-pp__stage:last-child h3{color:var(--nb-home-teal);}
#nb-pp-{{ section.id }} .nb-pp__stage p{max-width:22ch;margin:0 auto;font-size:var(--nb-home-type-microcopy);line-height:1.58;opacity:.82;}
#nb-pp-{{ section.id }} .nb-pp__bridge{width:100%;max-width:none;margin:clamp(18px,2.4vw,30px) 0 0;padding-top:clamp(28px,3.8vw,44px);border-top:1px solid rgba(var(--color-foreground),.3);font-family:var(--font-heading--family);font-size:var(--nb-home-type-microcopy);font-style:italic;line-height:1.62;opacity:.74;}
#nb-pp-{{ section.id }} .button{min-height:48px;padding:0 24px;border-radius:999px;margin-top:26px;background:var(--nb-home-teal);color:#fff;font-size:var(--nb-home-type-button);font-weight:700;}
@media(max-width:749px){#nb-pp-{{ section.id }} .nb-pp__body{columns:auto;}#nb-pp-{{ section.id }} .nb-pp__model{display:block;margin-top:40px;padding-top:0;background:transparent;}#nb-pp-{{ section.id }} .nb-pp__model:before{left:8px;right:auto;top:2px;bottom:32px;width:1px;height:auto;}#nb-pp-{{ section.id }} .nb-pp__stage{padding:0 0 32px 38px;text-align:left;}#nb-pp-{{ section.id }} .nb-pp__dot{left:8px;top:2px;transform:translateX(-50%);width:10px;height:10px;}#nb-pp-{{ section.id }} .nb-pp__stage p{max-width:none;margin:0;} }
{% endstyle %}
{% schema %}
{
  "name": "NB — Performance Presence",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Homepage tone fallback",
      "default": "sage",
      "options": [
        { "value": "scheme", "label": "Use color scheme" },
        { "value": "sage", "label": "Pale sage" }
      ]
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "The Method"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    },
    {
      "type": "text",
      "id": "bridge",
      "label": "Bridge line"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Optional CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Optional CTA link"
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descriptor"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "NB — Performance to Presence"
    }
  ]
}
{% endschema %}
