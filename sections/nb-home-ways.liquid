<section id="nb-home-ways-{{ section.id }}" class="nb-home-ways color-{{ section.settings.color_scheme }}">
  <div class="nb-home-ways__wrap">
    {% if section.settings.overline != blank %}<p class="nb-home-ways__overline">{{ section.settings.overline }}</p>{% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <p class="nb-home-ways__intro">{{ section.settings.intro }}</p>
    <div class="nb-home-ways__grid">{% for block in section.blocks %}<article class="nb-home-ways__card" {{ block.shopify_attributes }}><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p>{% if block.settings.link_label != blank and block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>{% endif %}</article>{% endfor %}</div>
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}<div class="nb-home-ways__cta"><a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></div>{% endif %}
  </div>
</section>
{% style %}
#nb-home-ways-{{ section.id }}{--nb-home-ink:#223238;--nb-home-teal:#10636c;background:rgb(var(--color-background));color:rgb(var(--color-foreground));padding:clamp(90px,9vw,136px) 20px;}
#nb-home-ways-{{ section.id }} .nb-home-ways__wrap{max-width:1120px;margin:0 auto;}
#nb-home-ways-{{ section.id }} .nb-home-ways__overline{margin:0 0 12px;font-family:var(--font-body--family);font-size:var(--nb-home-type-overline);font-weight:650;letter-spacing:.17em;text-transform:uppercase;opacity:.58;line-height:1.35;}
#nb-home-ways-{{ section.id }} h2{margin:0;font-family:var(--font-heading--family);font-size:clamp(var(--nb-home-type-section-heading),4.3vw,66px);line-height:.98;letter-spacing:-.035em;font-weight:500;}
#nb-home-ways-{{ section.id }} .nb-home-ways__intro{max-width:48ch;margin:clamp(16px,1.8vw,22px) 0 clamp(42px,5vw,60px);font-style:italic;font-size:var(--nb-home-type-body);line-height:1.62;opacity:.72;}
#nb-home-ways-{{ section.id }} .nb-home-ways__grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));border-top:1px solid rgba(var(--color-foreground),.13);border-bottom:1px solid rgba(var(--color-foreground),.13);background:transparent;}
#nb-home-ways-{{ section.id }} .nb-home-ways__card{min-height:clamp(236px,22vw,276px);padding:clamp(34px,4.2vw,56px) clamp(32px,4vw,54px);border-right:1px solid rgba(var(--color-foreground),.11);border-bottom:1px solid rgba(var(--color-foreground),.11);display:flex;flex-direction:column;align-items:flex-start;}
#nb-home-ways-{{ section.id }} .nb-home-ways__card:nth-child(2n){border-right:0;}#nb-home-ways-{{ section.id }} .nb-home-ways__card:nth-last-child(-n+2){border-bottom:0;}
#nb-home-ways-{{ section.id }} h3{margin:0 0 clamp(16px,1.8vw,22px);font-family:var(--font-body--family);font-size:var(--nb-home-type-overline);letter-spacing:.15em;text-transform:uppercase;font-weight:650;opacity:.6;line-height:1.35;}
#nb-home-ways-{{ section.id }} .nb-home-ways__card p{margin:0 0 clamp(24px,2.5vw,32px);font-family:var(--font-heading--family);font-size:var(--nb-home-type-card-body);line-height:1.42;letter-spacing:-.012em;}
#nb-home-ways-{{ section.id }} .nb-home-ways__card a{position:relative;margin-top:auto;color:rgba(var(--color-foreground),.74);font-family:var(--font-body--family);font-size:clamp(13px,.85vw,15px);font-weight:600;letter-spacing:.04em;text-decoration:none;transition:color .22s ease,opacity .22s ease;}
#nb-home-ways-{{ section.id }} .nb-home-ways__card a::after{content:"";position:absolute;left:0;right:0;bottom:-5px;height:1px;background:currentColor;opacity:.42;transform:scaleX(.38);transform-origin:left;transition:transform .28s ease,opacity .28s ease;}
#nb-home-ways-{{ section.id }} .nb-home-ways__card a:hover,#nb-home-ways-{{ section.id }} .nb-home-ways__card a:focus-visible{color:var(--nb-home-teal);}
#nb-home-ways-{{ section.id }} .nb-home-ways__card a:hover::after,#nb-home-ways-{{ section.id }} .nb-home-ways__card a:focus-visible::after{opacity:.72;transform:scaleX(1);}
#nb-home-ways-{{ section.id }} .nb-home-ways__cta{display:flex;justify-content:center;margin-top:clamp(44px,5.4vw,66px);}#nb-home-ways-{{ section.id }} .button{min-height:48px;padding:0 24px;border-radius:999px;background:var(--nb-home-teal);color:#fff;font-size:var(--nb-home-type-button);font-weight:700;transition:background-color .2s ease,transform .2s ease;}
#nb-home-ways-{{ section.id }} .button:hover,#nb-home-ways-{{ section.id }} .button:focus-visible{background:#0c535b;transform:translateY(-1px);}
@media(max-width:989px){#nb-home-ways-{{ section.id }} .nb-home-ways__card{min-height:240px;padding:clamp(30px,4.6vw,44px);}}
@media(max-width:749px){#nb-home-ways-{{ section.id }}{padding:clamp(72px,18vw,96px) 20px;}#nb-home-ways-{{ section.id }} .nb-home-ways__intro{margin-bottom:34px;}#nb-home-ways-{{ section.id }} .nb-home-ways__grid{grid-template-columns:1fr;}#nb-home-ways-{{ section.id }} .nb-home-ways__card,#nb-home-ways-{{ section.id }} .nb-home-ways__card:nth-child(2n),#nb-home-ways-{{ section.id }} .nb-home-ways__card:nth-last-child(-n+2){min-height:0;border-right:0;border-bottom:1px solid rgba(var(--color-foreground),.11);}#nb-home-ways-{{ section.id }} .nb-home-ways__card:last-child{border-bottom:0;}#nb-home-ways-{{ section.id }} .nb-home-ways__cta{margin-top:38px;}}
{% endstyle %}
{% schema %}
{
  "name": "NB — Home ways",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Ways in"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Protective line"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "way",
      "name": "Way",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Copy"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "NB — Home ways"
    }
  ]
}
{% endschema %}
