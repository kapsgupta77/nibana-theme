<section id="nb-home-newsletter-{{ section.id }}" class="nb-home-newsletter color-{{ section.settings.color_scheme }}" style="--nb-newsletter-bg: {{ section.settings.background_color }}; --nb-newsletter-text: {{ section.settings.text_color }};">
  <div class="nb-home-newsletter__wrap">
    {% if section.settings.overline != blank %}<p class="nb-home-newsletter__overline">{{ section.settings.overline }}</p>{% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <div class="nb-home-newsletter__body">{{ section.settings.body }}</div>
    {% form 'customer', class: 'nb-home-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter,nibana-notes,source:homepage">
      <div class="nb-home-newsletter__field"><label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ section.settings.email_label }}</label><input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" autocomplete="email" placeholder="{{ section.settings.email_placeholder }}" required><button class="button" type="submit">{{ section.settings.button_label }}</button></div>
      {% if form.posted_successfully? %}<p class="nb-home-newsletter__message" tabindex="-1">{{ section.settings.success_message }}</p>{% endif %}
      {% if form.errors %}<div class="nb-home-newsletter__message nb-home-newsletter__message--error">{{ form.errors | default_errors }}</div>{% endif %}
    {% endform %}
    {% if section.settings.microcopy != blank %}<p class="nb-home-newsletter__microcopy">{{ section.settings.microcopy }}</p>{% endif %}
  </div>
</section>
{% style %}
#nb-home-newsletter-{{ section.id }}{background:var(--nb-newsletter-bg,#0f6970);color:var(--nb-newsletter-text,#f7f1e8);padding:clamp(76px,7.5vw,112px) 20px;text-align:center;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__wrap{max-width:760px;margin:0 auto;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__overline{margin:0 0 10px;font-size:clamp(1.05rem,.72vw,1.18rem);letter-spacing:.13em;text-transform:uppercase;opacity:.68;line-height:1.35;}
#nb-home-newsletter-{{ section.id }} h2{margin:0 auto 14px;max-width:19ch;font-family:var(--font-heading--family);font-size:clamp(3.1rem,3.7vw,5.25rem);line-height:1.04;letter-spacing:-.032em;font-weight:500;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__body{font-size:clamp(1.32rem,1.08vw,1.56rem);line-height:1.62;opacity:.9;}#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__body p{margin:0 0 .7em;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__form{margin:32px auto 0;max-width:590px;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__field{display:flex;gap:0;justify-content:center;border:1px solid rgba(255,255,255,.44);background:rgba(255,255,255,.12);padding:6px;}
#nb-home-newsletter-{{ section.id }} input{flex:1;min-width:0;min-height:48px;border:0;background:#f7f1e8;color:#1f2c2a;padding:0 18px;border-radius:0;font-size:1.25rem;}
#nb-home-newsletter-{{ section.id }} .button{min-height:48px;padding:0 24px;background:#223238;color:#f7f1e8;white-space:nowrap;border-radius:999px;font-size:1.24rem;font-weight:700;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__microcopy,#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__message{margin:14px 0 0;font-size:1.08rem;line-height:1.5;opacity:.68;}
#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__message--error{color:#fff;text-align:left;}
@media(max-width:749px){#nb-home-newsletter-{{ section.id }} .nb-home-newsletter__field{flex-direction:column;}#nb-home-newsletter-{{ section.id }} .button{justify-content:center;}}
{% endstyle %}
{% schema %}
{
  "name": "NB — Home newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback",
      "default": "#0f6970"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text fallback",
      "default": "#f7f1e8"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Nibana Notes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join the list"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for joining Nibana Notes."
    }
  ],
  "presets": [
    {
      "name": "NB — Home newsletter"
    }
  ]
}
{% endschema %}
