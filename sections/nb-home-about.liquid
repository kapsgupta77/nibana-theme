<section id="nb-home-about-{{ section.id }}" class="nb-home-about color-{{ section.settings.color_scheme }}">
  <div class="nb-home-about__wrap">
    <div class="nb-home-about__media">
      <iframe
        class="nb-home-about__video"
        src="https://www.youtube.com/embed/sdTy9IZR87k?start=18&rel=0&modestbranding=1"
        title="Why I do this work video"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
    <div class="nb-home-about__copy">
      {% if section.settings.overline != blank %}<p class="nb-home-about__overline">{{ section.settings.overline }}</p>{% endif %}
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
      <div class="nb-home-about__body">{{ section.settings.body }}</div>
      <div class="nb-home-about__credentials">{% for block in section.blocks %}<span {{ block.shopify_attributes }}>{{ block.settings.label }}</span>{% endfor %}</div>
    </div>
  </div>
</section>
{% style %}
#nb-home-about-{{ section.id }}{--nb-home-ink:#223238;--nb-home-teal:#10636c;background:rgb(var(--color-background));color:rgb(var(--color-foreground));padding:clamp(72px,7.8vw,112px) 20px;}
#nb-home-about-{{ section.id }} .nb-home-about__wrap{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:minmax(360px,1.05fr) minmax(0,.95fr);gap:clamp(56px,7vw,96px);align-items:center;}
#nb-home-about-{{ section.id }} .nb-home-about__video{width:100%;height:auto;aspect-ratio:16/9;display:block;border:0;box-shadow:none;}
#nb-home-about-{{ section.id }} .nb-home-about__overline{margin:0 0 10px;font-size:var(--nb-home-type-overline);letter-spacing:.13em;text-transform:uppercase;opacity:.64;line-height:1.35;}
#nb-home-about-{{ section.id }} h2{margin:0 0 22px;font-family:var(--font-heading--family);font-size:var(--nb-home-type-section-heading);line-height:1.03;letter-spacing:-.032em;font-weight:500;}
#nb-home-about-{{ section.id }} .nb-home-about__body{font-size:var(--nb-home-type-body);line-height:1.7;max-width:58ch;}
#nb-home-about-{{ section.id }} .nb-home-about__body p{margin:0 0 1em;}
#nb-home-about-{{ section.id }} .nb-home-about__credentials{border-top:1px solid rgba(var(--color-foreground),.14);margin-top:28px;padding-top:18px;display:flex;gap:10px 22px;flex-wrap:wrap;font-size:var(--nb-home-type-credential);letter-spacing:.1em;text-transform:uppercase;opacity:.82;line-height:1.45;}
@media(max-width:749px){#nb-home-about-{{ section.id }} .nb-home-about__wrap{grid-template-columns:1fr;}#nb-home-about-{{ section.id }} .nb-home-about__media{max-width:360px;} }
{% endstyle %}
{% schema %}
{
  "name": "NB — Home about",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Kapil Gupta"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NB — Home about"
    }
  ]
}
{% endschema %}
