<section id="nb-home-about-{{ section.id }}" class="nb-home-about color-{{ section.settings.color_scheme }}">
  <div class="nb-home-about__wrap">
    <div class="nb-home-about__media">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(min-width: 990px) 36vw, 100vw', class: 'nb-home-about__image' }}{% endif %}</div>
    <div class="nb-home-about__copy">
      {% if section.settings.overline != blank %}<p class="nb-home-about__overline">{{ section.settings.overline }}</p>{% endif %}
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
      <div class="nb-home-about__body">{{ section.settings.body }}</div>
      <div class="nb-home-about__credentials">{% for block in section.blocks %}<span {{ block.shopify_attributes }}>{{ block.settings.label }}</span>{% endfor %}</div>
    </div>
  </div>
</section>
{% style %}
#nb-home-about-{{ section.id }}{--nb-home-ink:#223238;--nb-home-teal:#10636c;--nb-home-eyebrow:{{ section.settings.overline_font_size }}px;--nb-home-display:{{ section.settings.heading_font_size }}px;--nb-home-body:{{ section.settings.body_font_size }}px;--nb-home-credentials:{{ section.settings.credentials_font_size }}px;background:rgb(var(--color-background));color:rgb(var(--color-foreground));padding:clamp(72px,7.8vw,112px) 20px;}
#nb-home-about-{{ section.id }} .nb-home-about__wrap{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:minmax(360px,1.05fr) minmax(0,.95fr);gap:clamp(56px,7vw,96px);align-items:center;}
#nb-home-about-{{ section.id }} .nb-home-about__image{width:100%;aspect-ratio:3/4;object-fit:cover;display:block;}
#nb-home-about-{{ section.id }} .nb-home-about__overline{margin:0 0 10px;font-size:var(--nb-home-eyebrow);letter-spacing:.13em;text-transform:uppercase;opacity:.64;line-height:1.35;}
#nb-home-about-{{ section.id }} h2{margin:0 0 22px;font-family:var(--font-heading--family);font-size:var(--nb-home-display);line-height:1.03;letter-spacing:-.032em;font-weight:500;}
#nb-home-about-{{ section.id }} .nb-home-about__body{font-size:var(--nb-home-body);line-height:1.7;max-width:58ch;}
#nb-home-about-{{ section.id }} .nb-home-about__body p{margin:0 0 1em;}
#nb-home-about-{{ section.id }} .nb-home-about__credentials{border-top:1px solid rgba(var(--color-foreground),.14);margin-top:28px;padding-top:18px;display:flex;gap:10px 22px;flex-wrap:wrap;font-size:var(--nb-home-credentials);letter-spacing:.1em;text-transform:uppercase;opacity:.82;line-height:1.45;}
@media(max-width:749px){#nb-home-about-{{ section.id }} .nb-home-about__wrap{grid-template-columns:1fr;}#nb-home-about-{{ section.id }} .nb-home-about__media{max-width:360px;} }
{% endstyle %}
{% schema %}
{
  "name": "NB — Home about",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Kapil Gupta"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "overline_font_size",
      "label": "Overline font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 28,
      "max": 96,
      "step": 1,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Paragraph font size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 21
    },
    {
      "type": "range",
      "id": "credentials_font_size",
      "label": "Credentials font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NB — Home about"
    }
  ]
}
{% endschema %}
