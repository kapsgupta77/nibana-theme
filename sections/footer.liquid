

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}
    {% if section.settings.section_height != "" %} {{ section.settings.section_height | prepend: "section--height-" }}{% endif %}
  "
>
  {% render 'background-media',
    background_media: section.settings.background_media,
    background_video: section.settings.video,
    background_video_position: section.settings.video_position,
    background_image: section.settings.background_image,
    background_image_position: section.settings.background_image_position
  %}

  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--{{ section.settings.content_direction }}
      section-content-wrapper
      {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {%  render 'spacing-style', settings: section.settings %}
    "
  >
    <div class="nb-footer__main">
      <div class="nb-footer__brand">
        <a href="{{ routes.root_url }}" class="nb-footer__logo-link" aria-label="{{ shop.name | escape }}">
          {%- if settings.logo != blank -%}
            {{
              settings.logo
              | image_url: width: 480
              | image_tag:
                width: settings.logo.width,
                height: settings.logo.height,
                widths: '160, 240, 320, 480',
                class: 'nb-footer__logo',
                alt: shop.name
            }}
          {%- else -%}
            <span class="nb-footer__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        <p class="nb-footer__tagline">From Performance to Presence</p>
        <p class="nb-footer__statement">
          Bespoke coaching for leaders, men, and seekers ready to move with more clarity, intimacy, and presence.
        </p>
      </div>

      <nav class="nb-footer__nav" aria-label="Footer navigation">
        <div class="nb-footer__column nb-footer__column--work">
          <h2 class="nb-footer__heading">The work</h2>
          <div class="nb-footer__work-grid">
            <ul class="nb-footer__links list-unstyled">
              <li><a href="/pages/executive-coaching">Executive Coaching</a></li>
              <li><a href="/pages/mens-coaching">Men's Coaching</a></li>
              <li><a href="/pages/relationship-coaching">Relationship Coaching</a></li>
              <li><a href="/pages/eros-orgasmic-meditation">Eros &amp; Orgasmic Meditation</a></li>
            </ul>
            <ul class="nb-footer__links list-unstyled">
              <li><a href="/pages/stress-management-coaching">Stress Management</a></li>
              <li><a href="/pages/self-discovery-transformational-coaching">Self Discovery</a></li>
              <li><a href="/pages/transformational-life-coaching">Transformational Life Coaching</a></li>
              <li><a href="/quiz">Take the Quiz</a></li>
            </ul>
          </div>
        </div>

        <div class="nb-footer__column">
          <h2 class="nb-footer__heading">About</h2>
          <ul class="nb-footer__links list-unstyled">
            <li><a href="/pages/about-us">About Kapil</a></li>
            <li><a href="/pages/media">Media &amp; Press</a></li>
            <li><a href="/pages/testimonial">Testimonials</a></li>
            <li><a href="/blogs/news">Writing</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          </ul>
        </div>

        <div class="nb-footer__column">
          <h2 class="nb-footer__heading">Connect</h2>
          <ul class="nb-footer__links list-unstyled">
            <li><a href="https://www.linkedin.com/in/kapilgupta/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
            <li><a href="https://www.instagram.com/kapsgupta/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href="https://nibananotes.substack.com/" target="_blank" rel="noopener noreferrer">Substack</a></li>
            <li><a href="https://www.youtube.com/@kapil-gupta" target="_blank" rel="noopener noreferrer">YouTube</a></li>
            <li><a href="https://www.tiktok.com/@kapilguptacoach" target="_blank" rel="noopener noreferrer">TikTok</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="nb-footer__legacy-blocks">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

<style>
  .footer_new .section-content-wrapper {
    display: flex;
    flex-direction: column;
    height: auto;
    min-height: 0;
    width: 100%;
  }

  .footer_new .section {
    min-height: auto;
  }


  .nb-footer__legacy-blocks {
    margin: clamp(42px, 5vw, 72px) auto 0;
    max-width: 1320px;
    padding-top: clamp(18px, 2vw, 26px);
    position: relative;
    width: 100%;
  }

  .nb-footer__legacy-blocks::before {
    background: linear-gradient(90deg, rgba(227, 228, 220, 0.42), rgba(209, 108, 40, 0.28), rgba(227, 228, 220, 0.08));
    content: "";
    height: 1px;
    left: 0;
    opacity: 0.72;
    position: absolute;
    right: 0;
    top: 0;
  }

  .nb-footer__legacy-blocks > :not(.footer-utilities) {
    display: none;
  }

  .nb-footer__legacy-blocks .footer-utilities {
    border-top: 0;
    justify-content: center;
    padding-top: 0;
    text-align: center;
  }

  .nb-footer__legacy-blocks .footer-utilities__group--left {
    align-items: center;
    gap: 8px 28px;
    justify-content: center;
    text-align: center;
  }

  .nb-footer__legacy-blocks .footer-utilities__text,
  .nb-footer__legacy-blocks .footer-utilities a {
    color: rgba(227, 228, 220, 0.62);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  .nb-footer__legacy-blocks .footer-utilities__group--right {
    display: none;
  }

  .nb-footer__main {
    align-items: flex-start;
    display: grid;
    gap: clamp(52px, 7vw, 120px);
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    margin-inline: auto;
    max-width: 1320px;
    padding-top: clamp(52px, 6vw, 84px);
    width: 100%;
  }

  .nb-footer__brand {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
  }

  .nb-footer__logo-link {
    color: inherit;
    display: inline-flex;
    text-decoration: none;
  }

  .nb-footer__logo {
    display: block;
    height: auto;
    max-width: clamp(150px, 11vw, 190px);
  }

  .nb-footer__logo-text {
    font-family: var(--font-heading--family, Montserrat, sans-serif);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .nb-footer__tagline {
    color: rgba(245, 246, 244, 0.78);
    font-family: Montserrat, var(--font-body--family), sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    line-height: 1.5;
    margin: 0;
    text-transform: uppercase;
  }

  .nb-footer__statement {
    color: rgba(245, 246, 244, 0.68);
    font-size: clamp(0.9rem, 0.95vw, 1rem);
    line-height: 1.65;
    margin: 8px 0 0;
    max-width: 30ch;
  }

  .nb-footer__column {
    min-width: 0;
  }

  .nb-footer__column--work {
    flex: 1.85 1 0;
  }

  .nb-footer__nav {
    display: grid;
    gap: clamp(32px, 4vw, 70px);
    grid-template-columns: minmax(410px, 1.65fr) minmax(130px, 0.7fr) minmax(130px, 0.7fr);
    min-width: 0;
    width: 100%;
  }

  .nb-footer__heading {
    color: rgba(227, 228, 220, 0.72);
    font-family: Montserrat, var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    line-height: 1.4;
    margin: 0 0 18px;
    padding-bottom: 13px;
    position: relative;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nb-footer__heading::after {
    background: linear-gradient(90deg, var(--nb-chocolate, #d16c28), rgba(227, 228, 220, 0));
    border-radius: 999px;
    bottom: 0;
    content: "";
    height: 1px;
    left: 0;
    opacity: 0.72;
    position: absolute;
    width: 44px;
  }

  .nb-footer__work-grid {
    display: grid;
    gap: clamp(24px, 3vw, 42px);
    grid-template-columns: repeat(2, minmax(175px, 1fr));
  }

  .nb-footer__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .nb-footer__links a {
    color: rgba(255, 255, 255, 0.9);
    display: inline;
    font-size: 0.9375rem;
    line-height: 1.5;
    text-decoration-color: transparent;
    text-decoration: none;
    text-underline-offset: 0.26em;
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }

  .nb-footer__links a:hover {
    color: var(--nb-gainsboro, #e3e4dc);
    text-decoration: underline;
    text-decoration-color: rgba(209, 108, 40, 0.78);
  }

  @media only screen and (max-width: 989px) {
    .nb-footer__main {
      grid-template-columns: 1fr;
      gap: clamp(34px, 6vw, 48px);
      padding-top: clamp(44px, 8vw, 72px);
    }

    .nb-footer__nav {
      grid-template-columns: minmax(0, 1.4fr) minmax(130px, 0.8fr) minmax(130px, 0.8fr);
    }
  }

  @media only screen and (max-width: 768px) {
    .footer_new .spacing-style.layout-panel-flex.layout-panel-flex--row.section-content-wrapper.mobile-column {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .nb-footer__nav {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .nb-footer__work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper footer_new",
  "tag": "footer",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "email-signup"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "footer-utilities"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        },
        {
          "value": "row",
          "label": "t:options.horizontal"
        }
      ],
      "default": "column"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "t:settings.vertical_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "checkbox",
      "id": "align_baseline",
      "label": "t:settings.align_baseline",
      "default": false,
      "visible_if": "{{ section.settings.vertical_alignment == 'flex-end' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction != 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "t:settings.height",
      "options": [
        {
          "value": "",
          "label": "t:options.auto"
        },
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "full-screen",
          "label": "t:options.full_screen"
        }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "background_media",
      "label": "t:settings.background_media",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "none"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.background_media == 'video' }}"
    },
    {
      "type": "select",
      "id": "video_position",
      "label": "t:settings.video_position",
      "options": [
        {
          "value": "cover",
          "label": "t:options.cover"
        },
        {
          "value": "contain",
          "label": "t:options.contain"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_media == 'video' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.background_media == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_position",
      "label": "t:settings.image_position",
      "options": [
        {
          "value": "cover",
          "label": "t:options.cover"
        },
        {
          "value": "fit",
          "label": "t:options.fit"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_media == 'image' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
