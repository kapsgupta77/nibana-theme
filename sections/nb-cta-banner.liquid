{%- comment -%}
  NB — CTA Banner
  Centered banner with heading, optional body text, and CTA button.
  Extends cta-bar.liquid by adding a body richtext field.
  Supports floating card container for consistent page treatment.
{%- endcomment -%}

{%- liquid
  assign heading    = section.settings.heading | default: ''
  assign body       = section.settings.body
  assign btn_label  = section.settings.button_label | default: ''
  assign btn_link   = section.settings.button_link | default: ''
  assign bg         = section.settings.bg_color | default: '#EAF4F3'
  assign txt        = section.settings.text_color | default: '#223238'
  assign btn_bg     = section.settings.button_color | default: '#0b656e'
  assign btn_hover  = section.settings.button_hover_color | default: '#07494f'
  assign btn_txt    = section.settings.button_text_color | default: '#ffffff'
  assign card_on    = section.settings.card_on
-%}

<section
  id="nb-cta-banner-{{ section.id }}"
  class="nb-cta-banner {% if card_on %}nb-cta-banner--card{% endif %}"
  style="
    --nb-ctab-bg: {{ bg }};
    --nb-ctab-txt: {{ txt }};
    --nb-ctab-btn: {{ btn_bg }};
    --nb-ctab-btn-hover: {{ btn_hover }};
    --nb-ctab-btn-txt: {{ btn_txt }};
    padding-block-start: {{ section.settings.pad_top | default: 0 }}px;
    padding-block-end: {{ section.settings.pad_bottom | default: 0 }}px;
  "
>
  <div class="nb-cta-banner__wrap">
    <div class="nb-cta-banner__inner">
      {%- if heading != blank -%}
        <h2 class="nb-cta-banner__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if body != blank -%}
        <div class="nb-rte nb-cta-banner__body">{{ body }}</div>
      {%- endif -%}

      {%- if btn_label != blank and btn_link != blank -%}
        <a class="nb-cta-banner__btn" href="{{ btn_link }}">{{ btn_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* Floating card container (class-based, no Liquid in CSS) */
  .nb-cta-banner--card .nb-cta-banner__wrap{
    max-width: min(1160px, 94vw);
    margin-inline: auto;
    border-radius: 20px;
    box-shadow: 0 10px 28px rgba(0,0,0,.06);
    overflow: hidden;
  }
</style>

{% style %}
  #nb-cta-banner-{{ section.id }} .nb-cta-banner__wrap{
    background: var(--nb-ctab-bg);
    padding: clamp(32px, 4vw, 64px) clamp(20px, 4vw, 40px);
  }

  #nb-cta-banner-{{ section.id }} .nb-cta-banner__inner{
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  #nb-cta-banner-{{ section.id }} .nb-cta-banner__heading{
    color: var(--nb-ctab-txt);
    font-weight: 800;
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin: 0 0 0.6em;
  }

  #nb-cta-banner-{{ section.id }} .nb-cta-banner__body{
    color: var(--nb-ctab-txt);
    line-height: 1.7;
    font-size: 1.05rem;
    margin: 0 0 1.5em;
    opacity: 0.9;
  }
  #nb-cta-banner-{{ section.id }} .nb-cta-banner__body p{
    margin: 0;
  }

  #nb-cta-banner-{{ section.id }} .nb-cta-banner__btn{
    display: inline-block;
    background: var(--nb-ctab-btn);
    color: var(--nb-ctab-btn-txt);
    padding: 14px 36px;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }
  #nb-cta-banner-{{ section.id }} .nb-cta-banner__btn:hover{
    background: var(--nb-ctab-btn-hover);
  }
{% endstyle %}

{% schema %}
{
  "name": "NB — CTA Banner",
  "tag": "section",
  "class": "nb-cta-banner-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body", "label": "Body text" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Book a Free Call" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Floating card container" },
    { "type": "checkbox", "id": "card_on", "label": "Wrap in floating card", "default": false },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#EAF4F3" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#223238" },
    { "type": "color", "id": "button_color", "label": "Button colour", "default": "#0b656e" },
    { "type": "color", "id": "button_hover_color", "label": "Button hover colour", "default": "#07494f" },
    { "type": "color", "id": "button_text_color", "label": "Button text colour", "default": "#ffffff" },

    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "pad_bottom", "label": "Bottom padding", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "NB — CTA Banner", "category": "Custom" }
  ]
}
{% endschema %}
