{%- comment -%}
  Homepage responsive typography tokens. Theme Editor settings define max desktop sizes;
  clamp() preserves responsive scaling across desktop, tablet, and mobile.
{%- endcomment -%}
{%- if template.name == 'index' -%}
  <style>
    #MainContent[data-template="index"] {
      --nb-home-type-overline: clamp(12px, .85vw, {{ settings.nb_home_overline_font_size }}px);
      --nb-home-type-hero-heading: clamp(58px, 5.8vw, {{ settings.nb_home_hero_heading_font_size }}px);
      --nb-home-type-section-heading: clamp(30px, 2.6vw, {{ settings.nb_home_section_heading_font_size }}px);
      --nb-home-type-editorial-body: clamp(25px, 2vw, {{ settings.nb_home_editorial_body_font_size }}px);
      --nb-home-type-body: clamp(16px, 1vw, {{ settings.nb_home_body_font_size }}px);
      --nb-home-type-card-body: clamp(22px, 1.55vw, {{ settings.nb_home_card_body_font_size }}px);
      --nb-home-type-quote: clamp(24px, 1.7vw, {{ settings.nb_home_quote_font_size }}px);
      --nb-home-type-credential: clamp(12px, .85vw, {{ settings.nb_home_credentials_font_size }}px);
      --nb-home-type-button: clamp(15px, 1vw, {{ settings.nb_home_button_font_size }}px);
      --nb-home-type-microcopy: clamp(13px, .9vw, {{ settings.nb_home_microcopy_font_size }}px);
    }
  </style>
{%- endif -%}
