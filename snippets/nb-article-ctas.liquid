{%- liquid
  assign mode = mode | default: 'mid'

  assign category = article.metafields.custom.primary_category | default: 'Relationships'
  assign subtopics = article.metafields.custom.subtopics | default: nil

  assign primary_type = article.metafields.custom.cta_primary_type | default: ''
  assign secondary_type = article.metafields.custom.cta_secondary_type | default: ''

  if primary_type == '' or secondary_type == ''
    case category
      when "Men’s Work"
        assign cat_primary = 'call'
        assign cat_secondary = 'quiz'
      when "Relationships"
        assign cat_primary = 'quiz'
        assign cat_secondary = 'call'
      when "Emotional Intelligence"
        assign cat_primary = 'quiz'
        assign cat_secondary = 'quiz'
      when "Leadership"
        assign cat_primary = 'call'
        assign cat_secondary = 'quiz'
      when "Embodiment"
        assign cat_primary = 'quiz'
        assign cat_secondary = 'call'
      when "Sexuality"
        assign cat_primary = 'quiz'
        assign cat_secondary = 'quiz'
      when "Self-Discovery"
        assign cat_primary = 'quiz'
        assign cat_secondary = 'call'
      else
        assign cat_primary = 'quiz'
        assign cat_secondary = 'call'
    endcase
  endif

  if primary_type == '' and cat_primary != blank
    assign primary_type = cat_primary
  endif
  if secondary_type == '' and cat_secondary != blank
    assign secondary_type = cat_secondary
  endif

  assign url_call_default = '/pages/book-a-call'
  assign url_quiz_default = '/pages/presence-score'

  assign url_primary = article.metafields.custom.cta_link | default: article.metafields.custom.cta_primary_url | default: ''
  assign url_secondary = article.metafields.custom.cta_secondary_url | default: ''

  if url_primary == ''
    case primary_type
      when 'call'
        assign url_primary = url_call_default
      when 'quiz', 'leadmagnet'
        assign url_primary = url_quiz_default
      else
        assign url_primary = url_call_default
    endcase
  endif

  if url_secondary == ''
    case secondary_type
      when 'call'
        assign url_secondary = url_call_default
      when 'quiz', 'leadmagnet'
        assign url_secondary = url_quiz_default
      else
        assign url_secondary = url_call_default
    endcase
  endif

  assign copy_heading_call = "Ready for your next chapter?"
  assign copy_body_call = "Let’s map what you want—and the first moves to get there."
  assign copy_button_call = article.metafields.custom.cta_label | default: "Book a private conversation"

  assign copy_heading_quiz = "Curious where you actually stand?"
  assign copy_body_quiz = "Take the free Presence Score assessment—a two-minute read on where you sit between performance and presence."
  assign copy_button_quiz = "Take the Presence Score"

  assign nuance = ''
  if subtopics
    for st in subtopics
      case st
        when 'Boundaries'
          assign nuance = "Includes a simple Boundaries practice you can try today."
        when 'Repair'
          assign nuance = "Plus a 3-step micro-repair you can use after conflict."
        when 'Desire'
          assign nuance = "Prompts to clarify your true desire—without shame."
        when 'IFS'
          assign nuance = "Grounded in parts-work (IFS) to meet your inner dynamics."
        when 'Shame'
          assign nuance = "Gentle, shame-aware language to keep your system safe."
      endcase
      if nuance != ''
        break
      endif
    endfor
  endif
-%}

{%- liquid
  assign wrap_classes = 'nb-cta-wrap'
  if mode == 'top'
    assign wrap_classes = wrap_classes | append: ' nb-cta-wrap--top'
  elsif mode == 'end'
    assign wrap_classes = wrap_classes | append: ' nb-cta-wrap--end'
  else
    assign wrap_classes = wrap_classes | append: ' nb-cta-wrap--mid'
  endif

  assign cta_type = ''
  if mode == 'mid' or mode == 'top'
    assign cta_type = 'quiz'
    assign heading = copy_heading_quiz
    assign body = copy_body_quiz
    assign button = copy_button_quiz
    assign url = url_quiz_default
  else
    case primary_type
      when 'call'
        assign cta_type = 'call'
        assign heading = copy_heading_call
        assign body = copy_body_call
        assign button = copy_button_call
        assign url = url_primary
      when 'quiz', 'leadmagnet'
        assign cta_type = 'quiz'
        assign heading = copy_heading_quiz
        assign body = copy_body_quiz
        assign button = copy_button_quiz
        assign url = url_primary
      else
        assign cta_type = 'call'
        assign heading = copy_heading_call
        assign body = copy_body_call
        assign button = copy_button_call
        assign url = url_primary
    endcase
  endif

  assign btn_modifier = ''
  if cta_type == 'call'
    assign btn_modifier = ' nb-btn--call'
  elsif cta_type != ''
    assign btn_modifier = ' nb-btn--noncall'
  endif
-%}
{%- capture _cta_card -%}
  <div class="nb-cta-panel">
    <div class="nb-cta-panel__inner">
      <div class="nb-cta-panel__grid">
        <div class="nb-cta-panel__content">
          <h3 class="nb-cta-panel__title">{{ heading }}</h3>
          <p class="nb-cta-panel__body">{{ body }}{% if nuance != '' %} <span class="nb-cta-panel__nuance">{{ nuance }}</span>{% endif %}</p>
        </div>
        <div class="nb-cta-panel__action">
          <a class="nb-cta-panel__btn{{ btn_modifier }}" data-cta-type="{{ cta_type }}" href="{{ url }}">{{ button }}</a>
        </div>
      </div>
    </div>
  </div>
{%- endcapture -%}
<div class="{{ wrap_classes }}">{{ _cta_card }}</div>

{% stylesheet %}
  /* === CTA callout — restyled per Option B / CTA Callout mockups === */

  /* Mid: text-only, teal underlined link, no panel/fill/border-box */
  .nb-cta-wrap--mid{
    max-width: var(--normal-content-width);
    margin: clamp(1.75rem, 4vw, 3rem) auto;
  }
  .nb-cta-wrap--mid .nb-cta-panel,
  .nb-cta-wrap--mid .nb-cta-panel__inner{
    background:none; box-shadow:none; border:0; padding:0;
  }
  .nb-cta-wrap--mid .nb-cta-panel__grid{
    display:flex; flex-direction:column; gap:.4rem; text-align:left;
    border-top:1px solid var(--nb-gainsboro, #e3e4dc);
    border-bottom:1px solid var(--nb-gainsboro, #e3e4dc);
    padding: 1.1rem 0;
  }
  .nb-cta-wrap--mid .nb-cta-panel__title{
    margin:0; font-family: var(--font-h1--family, var(--font-heading--family));
    font-size:1.15rem; font-weight:500; color: var(--nb-ink, #2f3e48);
  }
  .nb-cta-wrap--mid .nb-cta-panel__body{ margin:0; color: var(--nb-muted, #51615d); font-size:.98rem; }
  .nb-cta-wrap--mid .nb-cta-panel__action{ margin-top:.35rem; }
  .nb-cta-wrap--mid .nb-cta-panel__btn{
    display:inline; padding:0; border:0; border-radius:0; background:none;
    color: var(--nb-teal, #10636c); text-decoration:underline; text-underline-offset:3px;
    font-weight:600;
  }
  .nb-cta-wrap--mid .nb-cta-panel__btn:hover{ color: var(--nb-teal-700, #0f5b62); }

  /* End: full-width Pebble field, no card chrome ("field rotation") */
  .nb-cta-wrap--end{
    width:100vw; margin-left:calc(50% - 50vw); margin-right:calc(50% - 50vw);
    background: var(--nb-pebble, #d2cbc8);
    padding: clamp(2.25rem, 5vw, 3.5rem) 1.25rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .nb-cta-wrap--end .nb-cta-panel,
  .nb-cta-wrap--end .nb-cta-panel__inner{ background:none; box-shadow:none; border:0; border-radius:0; padding:0; }
  .nb-cta-wrap--end .nb-cta-panel__grid{
    display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:1.5rem;
    max-width: var(--wide-content-width, 1100px); margin:0 auto;
  }
  .nb-cta-wrap--end .nb-cta-panel__title{
    margin:0 0 .5rem; font-family: var(--font-h1--family, var(--font-heading--family));
    font-weight:500; font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem); color: var(--nb-ink, #2f3e48);
  }
  .nb-cta-wrap--end .nb-cta-panel__body{ margin:0; color: var(--nb-ink, #2f3e48); opacity:.85; max-width:46ch; }
  .nb-cta-wrap--end .nb-cta-panel__btn{
    display:inline-flex; align-items:center; justify-content:center; white-space:nowrap;
    padding:.85rem 1.6rem; border-radius:999px; background: var(--nb-teal, #10636c); color:#fff;
    text-decoration:none; font-weight:600;
    transition: background .2s ease, transform .2s ease;
  }
  .nb-cta-wrap--end .nb-cta-panel__btn:hover{ background: var(--nb-teal-700, #0f5b62); transform: translateY(-1px); }
{% endstylesheet %}
