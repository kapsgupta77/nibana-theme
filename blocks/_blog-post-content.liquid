

<div class="blog-post-content rte">
  <rte-formatter>
    {%- liquid
      assign raw = article.content
      assign parts = raw | split: '</p>'
      assign total = parts | size
      assign mid_index = total | times: 6 | divided_by: 10
    -%}
    {%- for part in parts -%}
      {%- if part != '' -%}{{ part }}</p>{%- endif -%}
      {%- if forloop.index == mid_index -%}
        {%- render 'nb-article-ctas', mode: 'mid' -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if total <= 1 -%}
      {%- render 'nb-article-ctas', mode: 'mid' -%}
    {%- endif -%}
  </rte-formatter>
</div>

{% stylesheet %}
  .blog-post-content {
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  /* Body paragraph rhythm — sitewide --font-paragraph--line-height resolves to 1.6
     (type_line_height_paragraph: "body-loose"); bump slightly for the article body
     and give paragraphs deliberate breathing room. The generic .rte rule in
     base.css only sets heading/list margins, so there's no p+p margin at all
     without this. Scoped here, not on --font-paragraph--*, since that variable
     also drives body text sitewide. */
  .blog-post-content.rte p {
    line-height: 1.7;
    margin-block-end: 1.2em;
  }

  /* In-body H2/H3 — Shopify's RTE emits plain h2/h3 tags, which pick up
     base.css's `h2 { font-family: var(--font-h2--family) }` rule. That variable
     resolves to --font-accent--family (Inter, settings.type_font_h2: "accent"),
     not the Cormorant serif the mockup uses — the same class of token-leaking-
     into-the-wrong-context bug as the H1/masthead cascade fixes above. Reuse the
     same --font-h1--family fallback chain rather than touching --font-h2--*
     globally, since that variable also drives H2s elsewhere on the site.
     type_case_h2 is already "none" (no uppercasing), so no text-transform
     override is needed here. */
  .blog-post-content.rte :is(h1, h2, h3, h4, h5, h6) {
    font-family: var(--font-h1--family, var(--font-heading--family));
    font-weight: 600;
    font-size: clamp(1.5rem, 1.3rem + 1vw, 1.85rem);
    line-height: 1.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.content",
  "settings": [],
  "presets": [
    {
      "name": "t:names.content"
    }
  ]
}
{% endschema %}
